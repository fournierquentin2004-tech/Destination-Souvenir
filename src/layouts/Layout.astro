---
interface Props {
    title?: string;
    description?: string;
    heroPage?: boolean;
    ogImage?: string;
    canonicalPath?: string;
}
const {
    title = "Destination Souvenir",
    description = "Découvre les meilleures destinations pour voyager entre amis",
    heroPage = false,
    ogImage = "/images/bora-bora-hero.jpg",
    canonicalPath = ""
} = Astro.props;

const siteUrl = "https://destinationsouvenir.com";
const canonical = `${siteUrl}${canonicalPath}`;
const ogImageFull = `${siteUrl}${ogImage}`;
---
<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Destination Souvenir" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageFull} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageFull} />

    <!-- Schema.org WebSite -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Destination Souvenir",
        "url": siteUrl,
        "description": "Blog voyage entre amis — guides, activités incontournables et bons plans pour les 18-35 ans.",
        "inLanguage": "fr-FR",
        "potentialAction": {
            "@type": "SearchAction",
            "target": `${siteUrl}/ou-partir?q={search_term_string}`,
            "query-input": "required name=search_term_string"
        }
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <slot name="head" />
</head>
<body>

    <!-- BARRE DE NAV — apparaît au scroll sur la home, toujours visible ailleurs -->
    <header class={heroPage ? "site-header site-header--hero" : "site-header site-header--solid"} id="site-header">
        <div class="header-inner">
            <a href="/" class="header-logo">
                <img src="/logo.png" alt="Destination Souvenir" />
            </a>
            <nav class="header-nav">
                <a href="/europe">Europe</a>
                <a href="/asie">Asie</a>
                <a href="/amerique">Amérique</a>
                <a href="/afrique">Afrique</a>
                <a href="/oceanie">Océanie</a>
            </nav>
            <a href="/ou-partir" class="header-cta">Où partir ?</a>
            <button class="burger" aria-label="Menu" id="burger-btn">
                <span></span><span></span><span></span>
            </button>
        </div>
    </header>

    <!-- MENU MOBILE -->
    <div class="mobile-backdrop" id="mobile-backdrop"></div>
    <div class="mobile-menu" id="mobile-menu">
        <div class="mobile-menu-top">
            <img src="/logo.png" alt="Destination Souvenir" class="mobile-menu-logo" />
            <button class="mobile-close" id="mobile-close">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="mobile-menu-divider"></div>
        <nav class="mobile-nav">
            <a href="/europe" class="mobile-nav-link">
                <span class="mobile-nav-label">Europe</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <a href="/asie" class="mobile-nav-link">
                <span class="mobile-nav-label">Asie</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <a href="/amerique" class="mobile-nav-link">
                <span class="mobile-nav-label">Amérique</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <a href="/afrique" class="mobile-nav-link">
                <span class="mobile-nav-label">Afrique</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <a href="/oceanie" class="mobile-nav-link">
                <span class="mobile-nav-label">Océanie</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
        </nav>
        <div class="mobile-menu-footer">
            <a href="/ou-partir" class="mobile-cta">Où partir ?</a>
        </div>
    </div>

    <main>
        <slot />
    </main>

    <footer>
        <div class="footer-inner">
            <div class="footer-top">
                <div class="footer-left">
                    <img src="/logo.png" alt="Destination Souvenir" class="footer-logo" />
                    <div class="footer-socials">
                        <a href="https://www.instagram.com/destinationsouvenir" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social-link">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                            Instagram
                        </a>
                        <a href="https://www.tiktok.com/@destinationsetsouvenirs" target="_blank" rel="noopener" aria-label="TikTok" class="footer-social-link">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
                            TikTok
                        </a>
                    </div>
                </div>
                <div class="footer-center">
                    <p class="footer-tagline">Vis. Voyage. Vibre.</p>
                </div>
                <div class="footer-cols">
                    <div>
                        <h4>Continents</h4>
                        <a href="/europe">Europe</a>
                        <a href="/asie">Asie</a>
                        <a href="/amerique">Amérique</a>
                        <a href="/afrique">Afrique</a>
                        <a href="/oceanie">Océanie</a>
                    </div>
                    <div>
                        <h4>Le site</h4>
                        <a href="/conditions-generales-dutilisation">Conditions Générales d'Utilisation</a>
                        <a href="/mentions-legales">Mentions légales</a>
                        <a href="/politique-de-confidentialite">Politique de confidentialité</a>
                        <div class="footer-socials-mobile">
                            <a href="https://www.instagram.com/destinationsouvenir" target="_blank" rel="noopener">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                                Instagram
                            </a>
                            <a href="https://www.tiktok.com/@destinationsetsouvenirs" target="_blank" rel="noopener">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
                                TikTok
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Destination Souvenir — Tous droits réservés</p>
            </div>
        </div>
    </footer>

    <!-- Bouton retour en haut -->
    <button id="back-to-top" aria-label="Retour en haut">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 17 12 11 18 17"/>
            <polyline points="6 11 12 5 18 11"/>
        </svg>
    </button>

    <script>
        // Scroll : header apparaît
        const header = document.getElementById("site-header");
        if (header?.classList.contains("site-header--hero")) {
            window.addEventListener("scroll", () => {
                header.classList.toggle("visible", window.scrollY > 80);
            });
        }

        // Menu mobile
        const burger = document.getElementById("burger-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const mobileClose = document.getElementById("mobile-close");
        const backdrop = document.getElementById("mobile-backdrop");

        function openMenu() {
            mobileMenu?.classList.add("open");
            backdrop?.classList.add("open");
            document.body.style.overflow = "hidden";
        }
        function closeMenu() {
            mobileMenu?.classList.remove("open");
            backdrop?.classList.remove("open");
            document.body.style.overflow = "";
        }

        burger?.addEventListener("click", openMenu);
        mobileClose?.addEventListener("click", closeMenu);
        backdrop?.addEventListener("click", closeMenu);

        // Active les transitions seulement après le chargement (évite l'animation au démarrage)
        requestAnimationFrame(() => {
            mobileMenu?.classList.add("ready");
            backdrop?.classList.add("ready");
        });

        // Bouton retour en haut
        const backToTop = document.getElementById("back-to-top");
        window.addEventListener("scroll", () => {
            if (backToTop) {
                backToTop.classList.toggle("visible", window.scrollY > window.innerHeight * 0.8);
            }
        }, { passive: true });
        backToTop?.addEventListener("click", () => {
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    </script>
</body>
</html>

<style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --green-dark:      #0d1b2e;
        --green:           #1aa898;
        --green-light:     #3dcbbf;
        --turquoise:       #1aa898;
        --turquoise-light: #3dcbbf;
        --sand:            #f0dfa8;
        --sand-light:      #faf8f2;
        --sand-dark:       #d4a030;
        --text:            #0d1b2e;
        --text-muted:      #5a6a7a;
        --white:           #ffffff;
        --font-serif:      'Playfair Display', Georgia, serif;
        --font-sans:       'Poppins', sans-serif;
        --font-body:       'Inter', sans-serif;
    }

    html {
        scroll-behavior: smooth;
        overflow-x: hidden;
    }

    body {
        background: var(--sand-light);
        color: var(--text);
        font-family: var(--font-body);
        line-height: 1.6;
        overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; }
    img { display: block; backface-visibility: hidden; transform: translateZ(0); }

    /* ── HEADER ── */
    .site-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        transition: background 0.35s, box-shadow 0.35s, padding 0.35s, backdrop-filter 0.35s;
    }

    .site-header--solid {
        background: rgba(13,27,46,0.97);
        backdrop-filter: blur(12px);
        box-shadow: 0 2px 24px rgba(0,0,0,0.25);
    }

    .site-header--hero {
        background: transparent;
    }

    .site-header--hero.visible {
        background: rgba(13,27,46,0.97);
        backdrop-filter: blur(12px);
        box-shadow: 0 2px 24px rgba(0,0,0,0.25);
    }

    .header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1.4rem 2rem;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 2rem;
        transition: padding 0.35s;
    }

    .site-header--hero.visible .header-inner,
    .site-header--solid .header-inner {
        padding: 0.85rem 2rem;
    }

    .header-logo img {
        height: 75px;
        width: auto;
        filter: brightness(0) invert(1) drop-shadow(0 2px 12px rgba(0,0,0,0.75));
    }

    .header-nav {
        display: flex;
        gap: 2.2rem;
        justify-content: center;
    }

    .header-nav a {
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 600;
        color: rgba(255,255,255,0.92);
        transition: color 0.25s;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        position: relative;
        text-shadow: 0 1px 10px rgba(0,0,0,0.65);
    }

    .header-nav a::after {
        content: '';
        position: absolute;
        bottom: -3px; left: 0;
        width: 0; height: 1px;
        background: var(--turquoise);
        transition: width 0.3s;
    }

    .header-nav a:hover { color: #fff; }
    .header-nav a:hover::after { width: 100%; }

    .header-cta {
        background: #3dcbbf;
        color: #fff;
        padding: 0.55rem 1.3rem;
        border-radius: 6px;
        justify-self: end;
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        white-space: nowrap;
    }

    .header-cta:hover {
        background: #5eeae0;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(64,201,176,0.4);
    }

    .site-header--hero.visible .header-cta {
        background: #fff;
        color: var(--green-dark);
    }

    .site-header--hero.visible .header-cta:hover {
        background: rgba(255,255,255,0.88);
        box-shadow: 0 4px 16px rgba(255,255,255,0.2);
    }

    .burger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        margin-left: auto;
    }

    .burger span {
        display: block;
        width: 24px;
        height: 2px;
        background: #fff;
        border-radius: 2px;
        transition: background 0.2s;
    }

    /* MOBILE MENU — backdrop */
    .mobile-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(2px);
        z-index: 290;
        opacity: 0;
        pointer-events: none;
    }
    .mobile-backdrop.ready { transition: opacity 0.35s; }
    .mobile-backdrop.open {
        opacity: 1;
        pointer-events: auto;
    }

    /* MOBILE MENU — drawer */
    .mobile-menu {
        position: fixed;
        top: 0; right: 0; bottom: 0;
        width: 85%;
        max-width: 340px;
        background: var(--green-dark);
        z-index: 300;
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        overflow-y: auto;
    }
    .mobile-menu.ready { transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); }
    .mobile-menu.open { transform: translateX(0); }

    /* top: logo + close */
    .mobile-menu-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.3rem 1.5rem;
    }
    .mobile-menu-logo {
        height: 52px;
        width: auto;
        filter: brightness(0) invert(1);
    }
    .mobile-close {
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.75);
        cursor: pointer;
        transition: background 0.2s;
    }
    .mobile-close:hover { background: rgba(255,255,255,0.14); }

    /* divider */
    .mobile-menu-divider {
        height: 1px;
        background: rgba(255,255,255,0.08);
        margin: 0 1.5rem;
    }

    /* nav links */
    .mobile-nav {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 0.5rem 0;
    }
    .mobile-nav-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.5rem;
        font-family: var(--font-sans);
        font-size: 1.05rem;
        font-weight: 600;
        color: rgba(255,255,255,0.88);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: background 0.2s, color 0.2s;
    }
    .mobile-nav-link:hover {
        background: rgba(26,168,152,0.1);
        color: var(--turquoise-light);
    }
    .mobile-nav-link svg {
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
        transition: color 0.2s, transform 0.2s;
    }
    .mobile-nav-link:hover svg {
        color: var(--turquoise-light);
        transform: translateX(3px);
    }

    /* footer: CTA + socials */
    .mobile-menu-footer {
        padding: 1rem 1.5rem 3rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
        border-top: 1px solid rgba(255,255,255,0.08);
    }
    .mobile-cta {
        display: block;
        width: 100%;
        text-align: center;
        background: #fff;
        color: var(--green-dark);
        padding: 0.9rem 1.5rem;
        border-radius: 8px;
        font-family: var(--font-sans);
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: background 0.2s, transform 0.15s;
    }
    .mobile-cta:hover {
        background: rgba(255,255,255,0.88);
        transform: translateY(-1px);
    }
    .mobile-socials {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .mobile-socials span { color: rgba(255,255,255,0.3); font-size: 0.75rem; }
    .mobile-socials a {
        color: rgba(255,255,255,0.55);
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 500;
        transition: color 0.2s;
    }
    .mobile-socials a:hover { color: var(--turquoise-light); }

    /* ── BACK TO TOP ── */
    #back-to-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--turquoise);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.3s, transform 0.3s, background 0.2s;
        pointer-events: none;
        z-index: 999;
    }

    #back-to-top.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    #back-to-top:hover {
        background: var(--turquoise-light);
    }

    /* ── FOOTER ── */
    footer {
        background: #0d1b2e;
        color: rgba(255,255,255,0.6);
        padding: 2.5rem 2rem 1.5rem;
    }

    .footer-inner { max-width: 1280px; margin: 0 auto; }

    .footer-top {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .footer-left {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        align-items: center;
    }

    .footer-logo { height: 120px; width: auto; filter: brightness(0) invert(1); }

    .footer-center {
        text-align: center;
    }

    .footer-tagline {
        font-family: var(--font-serif);
        font-size: 2rem;
        font-weight: 700;
        font-style: italic;
        color: #fff;
        line-height: 1.2;
    }

    .footer-socials {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .footer-social-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #fff;
        font-size: 0.82rem;
        font-family: var(--font-sans);
        font-weight: 600;
        transition: color 0.2s;
    }

    .footer-social-link:hover { color: var(--turquoise-light); }

    .footer-cols {
        display: flex;
        gap: 3rem;
        justify-content: flex-end;
    }

    .footer-cols h4 {
        font-family: var(--font-sans);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--turquoise);
        margin-bottom: 0.7rem;
    }

    .footer-cols a {
        display: block;
        font-size: 0.82rem;
        color: #fff;
        margin-bottom: 0.35rem;
        transition: color 0.2s;
    }

    .footer-cols a:hover { color: var(--turquoise-light); }

    .footer-socials-mobile { display: none; }

    .footer-bottom {
        padding-top: 1rem;
        font-size: 0.75rem;
        color: #fff;
        text-align: center;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 767px), (max-width: 1024px) and (orientation: portrait) {
        .header-nav, .header-cta { display: none; }
        .burger { display: flex; grid-column: 3; grid-row: 1; justify-self: end; filter: drop-shadow(0 1px 6px rgba(0,0,0,0.7)); }
