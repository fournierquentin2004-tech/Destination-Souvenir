---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Nage avec les dauphins à Mnemba", desc: "Plonge dans un rêve bleu au large de Zanzibar : rencontre les dauphins dans leur paradis naturel, explore les récifs multicolores de Mnemba et savoure un instant de bonheur sur ces eaux turquoise, bercé par la douceur de l'océan Indien.", img: "/images/Zanzibar%20blog/1.webp", alt: "Femme sous l'eau nageant avec les dauphins à l'île de Mnemba, Zanzibar", lien: "https://www.getyourguide.com/fr-fr/zanzibar-l871/ile-de-mnemba-nage-avec-les-dauphins-et-plongee-avec-tuba-avec-dejeuner-en-option-t608498/?ranking_uuid=12de050a-6aef-4a10-9552-adae0847ecaf" },
    { titre: "Prison Island & plage de Nakupenda", desc: "Explore Prison Island et découvre ses tortues centenaires, nage dans les eaux cristallines, savoure un déjeuner local, puis détends-toi sur le sable immaculé de Nakupenda sous le soleil tropical. Une journée paradisiaque avec tes amis !", img: "/images/Zanzibar%20blog/2.webp", alt: "Plage paradisiaque de Nakupenda avec sable blanc et eaux turquoise à Zanzibar", lien: "https://www.getyourguide.com/fr-fr/archipel-de-zanzibar-l95591/zanzibar-excursion-en-bateau-a-prison-island-et-nakupenda-avec-dejeuner-t594405/?ranking_uuid=12de050a-6aef-4a10-9552-adae0847ecaf" },
    { titre: "Safari au parc national de Mikumi", desc: "Vis une aventure sauvage au parc national de Mikumi : observe des lions, éléphants et girafes évoluer librement dans de vastes plaines, savoure un déjeuner au cœur de la brousse et contemple le soleil se coucher sur ces plaines infinies — un moment inoubliable.", img: "/images/Zanzibar%20blog/3.webp", alt: "Panthère dans un arbre au parc national de Mikumi lors d'un safari depuis Zanzibar", lien: "https://www.getyourguide.com/fr-fr/zanzibar-ville-l872/depuis-zanzibar-excursion-d-une-journee-au-parc-national-de-mikumi-avec-vols-et-dejeuner-t436276/?ranking_uuid=12de050a-6aef-4a10-9552-adae0847ecaf" },
];

const hebergements = [
    { type: "Nungwi & Kendwa", ex: "Plages magnifiques, ambiance festive et activités", desc: "La côte nord de Zanzibar, c'est LE spot pour un groupe en quête d'ambiance. Plages de rêve, soirées animées au bord de l'eau, beach bars et nombreuses excursions. Kendwa accueille des full moon parties légendaires — parfait pour un séjour festif les pieds dans le sable.", tag: "Festif" },
    { type: "Paje & Jambiani", ex: "Kitesurf, cafés branchés et atmosphère jeune", desc: "La côte est pour ceux qui veulent sortir des sentiers battus. Paje est le paradis du kitesurf avec ses cafés branchés et beach bars. Jambiani offre une ambiance plus authentique et calme, idéale pour un groupe qui cherche à se ressourcer loin du tourisme de masse.", tag: "Équilibre" },
    { type: "Stone Town", ex: "Culture swahilie, restaurants et vie nocturne locale", desc: "Le cœur historique classé au patrimoine mondial de l'UNESCO. Ruelles labyrinthiques, épices envoutantes, marchés colorés et restaurants de fruits de mer — Stone Town est parfait pour explorer la culture swahilie et profiter d'une nightlife locale authentique à petit prix.", tag: "Culture" },
];

const transports = [
    { nom: "Taxi", desc: "Abordable et pratique pour se déplacer entre les quartiers et de l'aéroport à ton hébergement. Négocie toujours le prix à l'avance — les taxis ne sont pas équipés de compteur. Pour l'aéroport, prévois environ 20–30 $ selon ta destination.", img: "/images/Zanzibar%20blog/5.webp", alt: "Taxi à Zanzibar pour se déplacer sur l'île" },
    { nom: "Scooter & moto-taxi", desc: "La liberté totale pour explorer l'île à ton rythme, de Nungwi à Paje en passant par Stone Town. Location disponible partout pour 15–25 $/jour. Attention aux routes non éclairées le soir et aux pistes glissantes par temps de pluie.", img: "/images/Zanzibar%20blog/14.webp", alt: "Scooter pour explorer librement l'île de Zanzibar" },
    { nom: "Bateaux & excursions", desc: "Indispensables pour rejoindre les îlots paradisiaques comme Mnemba, Prison Island ou Nakupenda. Les excursions organisées incluent le transport en bateau. Pour le continent, le ferry relie Stone Town à Dar es Salaam en 2h.", img: "/images/Zanzibar%20blog/6.webp", alt: "Bateau traditionnel dhow à Zanzibar pour explorer les îles" },
];

const conseils = [
    { titre: "Période idéale", desc: "Décembre à février : saison chaude et sèche, 28–32 °C, mer calme — idéale pour le snorkeling et la plage. Évite les grandes pluies de mars–mai et d'octobre–novembre." },
    { titre: "Fortes marées", desc: "Préfère la côte nord (Nungwi, Kendwa) pour éviter les importantes marées de la côte est qui laissent parfois la mer très loin du rivage — surtout gênant pour la baignade à marée basse." },
    { titre: "Eau & santé", desc: "Ne bois que de l'eau en bouteille. Pense à la vaccination contre la fièvre typhoïde et l'hépatite A. Un traitement antipaludéen est recommandé pour les séjours prolongés ou les excursions sur le continent." },
    { titre: "Paiement", desc: "Beaucoup de petits commerces, restaurants locaux et taxis n'acceptent que le cash. Emporte suffisamment de shillings tanzaniens et de dollars US — les ATM de Stone Town sont les plus fiables." },
];

const faq = [
    { q: "Quelle est la meilleure période pour aller à Zanzibar ?", r: "De décembre à février : profite de la chaleur tropicale avec des températures agréables entre 28 et 32 °C, une mer calme et un ciel dégagé — la meilleure fenêtre pour le snorkeling, les plages et les excursions en bateau." },
    { q: "Quelles sont les meilleures activités à Zanzibar entre amis ?", r: "Les incontournables de Zanzibar : nager avec les dauphins à l'île de Mnemba, excursion à Prison Island avec les tortues centenaires et la sandbank de Nakupenda, safari au parc national de Mikumi, soirée à Kendwa et snorkeling sur les récifs coralliens de la côte nord." },
    { q: "Où dormir à Zanzibar entre amis ?", r: "Nungwi et Kendwa pour les plages et la vie nocturne, Paje pour le kitesurf et l'ambiance jeune, Jambiani pour le calme et l'authenticité, Stone Town pour la culture swahilie et les restaurants de fruits de mer. Le choix dépend de l'ambiance que tu recherches !" },
];

const similaires = [
    { titre: "Que faire aux Maldives entre amis", desc: "Overwater bungalows, plongée avec requins et snorkeling face à des lagons turquoise — les Maldives, le paradis absolu de l'océan Indien.", img: "/images/Maldives%20blog/1.webp", href: "/que-faire-aux-maldives-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Bora Bora entre amis", desc: "Lagons turquoise, plages désertes sur les motus et couchers de soleil en Polynésie française — Bora Bora, le joyau du Pacifique.", img: "/images/Bora%20Bora%20blog/1.webp", href: "/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Rio de Janeiro entre amis", desc: "Christ Rédempteur, favela Rocinha et plages de Copacabana — Rio, la ville la plus intense du monde qui te prend par les tripes.", img: "/images/Rio%20de%20Janeiro%20blog/1.webp", href: "/que-faire-a-rio-de-janeiro-entre-amis-guide-et-bons-plans", tag: "Amérique" },
];
---

<Layout
    title="Que faire à Zanzibar entre amis : guide et bons plans 2026"
    description="Dauphins à Mnemba, Prison Island et safari au Mikumi : notre guide complet pour préparer ton séjour à Zanzibar entre amis en Tanzanie."
    ogImage="/images/Zanzibar%20blog/10.webp"
    canonicalPath="/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
    touristName="Zanzibar"
    touristCountry="Tanzanie"
>
    <link rel="preload" as="image" href="/images/Zanzibar%20blog/10.webp" slot="head" />

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Zanzibar entre amis : guide et bons plans 2026",
        "description": "Dauphins à Mnemba, Prison Island et safari au Mikumi : notre guide complet pour préparer ton séjour à Zanzibar entre amis en Tanzanie.",
        "image": "https://destinationsouvenir.com/images/Zanzibar%20blog/10.webp",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2026-06-15",
        "dateModified": "2026-06-15",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelle est la meilleure période pour aller à Zanzibar ?", "acceptedAnswer": { "@type": "Answer", "text": "De décembre à février : profite de la chaleur tropicale avec des températures agréables entre 28 et 32 °C, une mer calme et un ciel dégagé — la meilleure fenêtre pour le snorkeling, les plages et les excursions en bateau." } },
            { "@type": "Question", "name": "Quelles sont les meilleures activités à Zanzibar entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables de Zanzibar : nager avec les dauphins à l'île de Mnemba, excursion à Prison Island avec les tortues centenaires et la sandbank de Nakupenda, safari au parc national de Mikumi, soirée à Kendwa et snorkeling sur les récifs coralliens de la côte nord." } },
            { "@type": "Question", "name": "Où dormir à Zanzibar entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Nungwi et Kendwa pour les plages et la vie nocturne, Paje pour le kitesurf et l'ambiance jeune, Jambiani pour le calme et l'authenticité, Stone Town pour la culture swahilie et les restaurants de fruits de mer." } }
        ]
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Afrique", "item": "https://destinationsouvenir.com/afrique" },
            { "@type": "ListItem", "position": 3, "name": "Zanzibar", "item": "https://destinationsouvenir.com/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Afrique &nbsp;·&nbsp; Tanzanie</p>
            <h1>Que faire à <em>Zanzibar</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Plages de sable blanc, dauphins en liberté et safaris mythiques… Zanzibar, c'est <em>l'île aux épices qui te marque à jamais.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Zanzibar entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <picture>
                                    <img src={a.img} alt={a.alt} loading="lazy" />
                                </picture>
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Zanzibar%20blog/13.webp" alt="Coucher de soleil spectaculaire sur l'océan Indien à Zanzibar" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Zanzibar%20blog/9.webp" alt="Plage de sable blanc de Zanzibar avec eaux turquoise" loading="lazy" />
            <img src="/images/Zanzibar%20blog/11.webp" alt="Ambiance sur une plage de Zanzibar en Tanzanie" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Zanzibar%20blog/16.webp" alt="Vue panoramique sur le lagon turquoise de Zanzibar" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Zanzibar%20blog/12.webp" alt="Hôtel en bord de mer à Zanzibar avec vue sur l'océan Indien" loading="lazy" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Zanzibar ?</em></h2>
                <p class="logements-sub">De la côte festive de Nungwi aux ruelles historiques de Stone Town — le quartier que tu choisis définit complètement l'ambiance de ton séjour à Zanzibar.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Zanzibar%20blog/12.webp" alt="Hôtel en bord de mer à Zanzibar avec vue sur l'océan Indien" loading="lazy" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hébergement plusieurs mois à l'avance pour profiter des meilleures offres, surtout en haute saison (décembre–février) où les établissements de Nungwi et Kendwa affichent complet très tôt !</span>
                </p>
                <a href="https://www.booking.com/hotel/tz/my-blue-ora-resort.fr.html" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Zanzibar</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Zanzibar&nbsp;?</em></h2>
                <p>Zanzibar est accessible et s'adapte à tous les budgets — des guesthouses locales aux resorts de luxe sur la côte nord.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">15 – 40 €</div>
                    <div class="btr-val">50 – 120 €</div>
                    <div class="btr-val btr-val--luxe">150 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">4 – 10 €</div>
                    <div class="btr-val">10 – 25 €</div>
                    <div class="btr-val btr-val--luxe">40 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">1 – 3 €</div>
                    <div class="btr-val">5 – 15 €</div>
                    <div class="btr-val btr-val--luxe">20 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val">40 – 80 €</div>
                    <div class="btr-val btr-val--luxe">100 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">450 – 800 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> il n'y a pas de vol direct depuis la France vers Zanzibar — la plupart des connexions passent par Nairobi, Addis-Abeba ou Dubaï. Réserve 4 à 6 mois à l'avance pour les meilleurs tarifs !</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Zanzibar ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à Zanzibar</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Zanzibar entre amis,<br /><em>l'île qui te marque à jamais</em></h2>
                <p>Zanzibar est une destination parfaite entre amis : plages dignes de cartes postales, soirées animées à Kendwa, excursions dauphins, rencontres avec les tortues centenaires, ambiance décontractée et nature sauvage au parc de Mikumi.</p>
                <p>Que tu sois plutôt plage, aventure ou fête, Zanzibar offre le mélange idéal pour créer des souvenirs inoubliables. L'île aux épices de l'océan Indien t'attend — tu n'auras plus envie de repartir !</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Zanzibar%20blog/13.webp" />
                    <img src="/images/Zanzibar%20blog/13.webp" alt="Coucher de soleil sur les eaux turquoise de l'océan Indien à Zanzibar" loading="lazy" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Zanzibar%20blog/9.webp" alt="Excursions et activités incontournables à Zanzibar avec GetYourGuide" loading="lazy" />
                    </div>
                    <a href="https://www.getyourguide.com/fr-fr/zanzibar-l871/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Zanzibar%20blog/4.webp" alt="Hôtel en bord de mer à Zanzibar, réservation sur Booking" loading="lazy" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Zanzibar" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/shared/cta-vols.webp" alt="Vol pour Zanzibar en Tanzanie, comparer sur Skyscanner" loading="lazy" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — Zanzibar entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = Math.max(0, Math.min(index, cards.length - 1));
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = Math.max(0, Math.min(index, simCards.length - 1));
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

