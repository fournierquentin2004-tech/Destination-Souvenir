---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Excursion paradisiaque", desc: "Pars à la découverte de plages et d'îles irréelles. Nage autour de Snake Island, explore les grottes mystérieuses de Cudugnon et de la Cathédrale, puis profite de l'île d'Entalula avec son sable blanc et ses eaux turquoise. Une journée inoubliable t'attend !", img: "/images/El%20Nido%20Philippines%20blog/6.jpg", imgMobile: "/images/El%20Nido%20Philippines%20blog/6.jpg", alt: "Excursion en bateau vers les îles paradisiaques d'El Nido, Philippines", lien: "https://www.getyourguide.com/fr-fr/el-nido-l974/mystic-shores-el-nido-tour-b-adventure-t581244/?ranking_uuid=a1a94a14-648e-49b6-8e15-9ef0e7607ba9" },
    { titre: "Lagon secret", desc: "Explore les îles paradisiaques d'El Nido. Plonge dans des lagons turquoise, détends-toi sur des plages de sable blanc et profite dans un lagon secret caché entre les falaises. Découvre ensuite l'île de Shimizu et la mythique plage Seven Commandos !", img: "/images/El%20Nido%20Philippines%20blog/8.jpg", alt: "Lagon secret caché entre les falaises calcaires d'El Nido, Philippines", lien: "https://www.getyourguide.com/fr-fr/el-nido-l974/el-nido-circuit-dans-les-iles-a-lagoons-et-plages-t217227/?ranking_uuid=3e7957b4-cf8c-4d5a-809a-d48a21f9810c" },
    { titre: "Expédition de rêve", desc: "Embarque pour une expédition de 3 jours entre El Nido et Coron à bord d'un bangka traditionnel. Explore des plages préservées, des criques secrètes et des îles inhabitées, plonge dans des récifs coralliens immaculés et nage dans des eaux cristallines. Passe un moment hors du temps !", img: "/images/El%20Nido%20Philippines%20blog/9.jpg", alt: "Expédition en bangka entre El Nido et Coron, Philippines", lien: "https://www.getyourguide.com/fr-fr/el-nido-l974/au-depart-d-el-nido-et-de-coron-circuit-de-3-jours-et-2-nuits-avec-circuit-dans-les-iles-t872937/?ranking_uuid=3e7957b4-cf8c-4d5a-809a-d48a21f9810c" },
];

const hebergements = [
    { type: "El Nido Town", ex: "Hostels, guesthouses et restaurants animés", desc: "Le cœur battant d'El Nido. Animé, central et à deux pas des bars, restaurants et agences d'excursion. Idéal pour être au milieu de l'action et rencontrer d'autres voyageurs.", tag: "Budget" },
    { type: "Caalan Beach / Las Cabanas", ex: "Bungalows face à la mer et couchers de soleil", desc: "L'option tranquille avec vue sur la mer. Plage accessible à pied, couchers de soleil époustouflants et une ambiance détendue loin de l'agitation du centre-ville.", tag: "Équilibre" },
    { type: "Lio Beach", ex: "Hôtels modernes, boutiques et calme absolu", desc: "La zone chic et paisible d'El Nido. Infrastructures modernes, plage propre et bien entretenue, et une atmosphère haut de gamme pour un séjour luxueux et serein.", tag: "Luxe" },
];

const transports = [
    { nom: "Bangka (bateau local)", desc: "Indispensable pour les excursions vers les lagons et les îles. Le bangka est le moyen de transport par excellence pour explorer les merveilles naturelles autour d'El Nido.", img: "/images/El%20Nido%20Philippines%20blog/2.jpg", alt: "Bateau bangka sur les eaux turquoise d'El Nido, Philippines" },
    { nom: "Scooter", desc: "Le plus pratique pour se déplacer librement sur l'île. Loue un scooter pour rejoindre les plages moins touristiques et explorer la région à ton rythme.", img: "/images/El%20Nido%20Philippines%20blog/16.jpg", alt: "Scooter pour explorer El Nido et Palawan, Philippines" },
    { nom: "Taxi / Van", desc: "Confortable pour les trajets plus longs, notamment depuis ou vers l'aéroport. Pratique en groupe pour partager les frais et voyager sans stress.", img: "/images/El%20Nido%20Philippines%20blog/17.jpg", alt: "Taxi ou van pour se déplacer à El Nido, Philippines" },
];

const conseils = [
    { titre: "Meilleure période", desc: "Novembre à mai — 29°C en moyenne, mer calme et ciel dégagé. La saison idéale pour profiter des lagons et des excursions en bateau." },
    { titre: "Période à éviter", desc: "De juin à octobre : fortes pluies, mer agitée et risque de typhons. Les excursions en bangka sont souvent annulées ou dangereuses." },
    { titre: "Réserve à l'avance", desc: "Activités et hébergements se remplissent très vite en haute saison. Réserve plusieurs semaines à l'avance pour éviter les déceptions." },
    { titre: "Vols", desc: "N'attends pas la dernière minute pour réserver ton vol vers El Nido — les prix grimpent rapidement dès que la saison commence." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire à El Nido entre amis ?", r: "Les incontournables : l'exploration du lagon secret caché entre les falaises, l'excursion island hopping vers Snake Island et Seven Commandos Beach, la plongée et le snorkeling dans des eaux cristallines, et l'expédition de 3 jours entre El Nido et Coron en bangka." },
    { q: "Où dormir à El Nido ?", r: "El Nido Town pour l'animation, les restaurants et la proximité des agences d'excursion. Las Cabanas ou Caalan Beach pour le calme et les couchers de soleil face à la mer. Lio Beach pour une ambiance chic et haut de gamme." },
    { q: "Quand partir à El Nido ?", r: "La période idéale pour partir à El Nido est de novembre à mai, avec des températures agréables autour de 29°C et une mer calme, parfaite pour les excursions en bateau et la plongée." },
];

const similaires = [
    { titre: "Que faire à Coron entre amis", desc: "Plages paradisiaques, épaves mythiques à explorer et couchers de soleil spectaculaires — Coron est le joyau caché des Philippines.", img: "/images/Coron%20blog/1.jpg", href: "/que-faire-a-coron-aux-philippines-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Koh Phi Phi entre amis", desc: "Eaux turquoise, plages de sable blanc et soirées les pieds dans le sable — Koh Phi Phi, c'est le paradis absolu.", img: "/images/Koh%20Phi%20Phi%20blog/5.jpg", href: "/que-faire-a-koh-phi-phi-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Bangkok entre amis", desc: "Tuk-tuk qui foncent, saveurs qui explosent, nuits sans fin — Bangkok se vit à mille à l'heure.", img: "/images/Bangkok%20blog/7.jpg", href: "/que-faire-a-bangkok-entre-amis-guide-et-bons-plans", tag: "Asie" },
];
---

<Layout
    title="Que faire à El Nido, Philippines : guide et bons plans 2026"
    description="Lagons secrets, falaises calcaires, island hopping et plages de rêve. Découvre notre guide complet pour un séjour inoubliable à El Nido entre amis."
    ogImage="/images/El%20Nido%20Philippines%20blog/1.jpg"
    canonicalPath="/que-faire-a-el-nido-aux-philippines-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
>
    <link rel="preload" as="image" href="/images/El%20Nido%20Philippines%20blog/1.jpg" slot="head" />

    <!-- Schema Article -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à El Nido, Philippines : guide et bons plans 2026",
        "description": "Lagons secrets, falaises calcaires, island hopping et plages de rêve. Découvre notre guide complet pour un séjour inoubliable à El Nido entre amis.",
        "image": "https://destinationsouvenir.com/images/El%20Nido%20Philippines%20blog/1.jpg",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2026-06-13",
        "dateModified": "2026-06-13",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-el-nido-aux-philippines-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <!-- Schema FAQPage -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire à El Nido entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables : l'exploration du lagon secret caché entre les falaises, l'excursion island hopping vers Snake Island et Seven Commandos Beach, la plongée et le snorkeling dans des eaux cristallines, et l'expédition de 3 jours entre El Nido et Coron en bangka." } },
            { "@type": "Question", "name": "Où dormir à El Nido ?", "acceptedAnswer": { "@type": "Answer", "text": "El Nido Town pour l'animation, les restaurants et la proximité des agences d'excursion. Las Cabanas ou Caalan Beach pour le calme et les couchers de soleil face à la mer. Lio Beach pour une ambiance chic et haut de gamme." } },
            { "@type": "Question", "name": "Quand partir à El Nido ?", "acceptedAnswer": { "@type": "Answer", "text": "La période idéale pour partir à El Nido est de novembre à mai, avec des températures agréables autour de 29°C et une mer calme, parfaite pour les excursions en bateau et la plongée." } }
        ]
    })}</script>

    <!-- Schema BreadcrumbList -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Asie", "item": "https://destinationsouvenir.com/asie" },
            { "@type": "ListItem", "position": 3, "name": "El Nido", "item": "https://destinationsouvenir.com/que-faire-a-el-nido-aux-philippines-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Asie &nbsp;·&nbsp; Philippines</p>
            <h1>Que faire à <em>El Nido</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Lagons secrets cachés entre des falaises calcaires, plages presque désertes, eaux turquoise à couper le souffle… El Nido, c'est <em>l'un des plus beaux endroits au monde.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à El Nido entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <picture>
                                    {a.imgMobile && <source media="(max-width: 767px)" srcset={a.imgMobile} />}
                                    <img src={a.img} alt={a.alt} loading="lazy" />
                                </picture>
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/El%20Nido%20Philippines%20blog/13.jpg" alt="Falaises calcaires et eaux turquoise d'El Nido, Philippines" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/El%20Nido%20Philippines%20blog/10.jpg" alt="Plage de sable blanc à El Nido, Philippines" loading="lazy" />
            <img src="/images/El%20Nido%20Philippines%20blog/3.jpg" alt="Lagon secret d'El Nido, Palawan, Philippines" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/El%20Nido%20Philippines%20blog/7.jpg" alt="Eaux cristallines et récifs coralliens à El Nido" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/El%20Nido%20Philippines%20blog/12.jpg" alt="Hébergement avec vue sur la mer à El Nido, Philippines" loading="lazy" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à El Nido ?</em></h2>
                <p class="logements-sub">D'El Nido Town animé aux bungalows face à la mer de Las Cabanas — le quartier que tu choisis change tout à ton séjour.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/El%20Nido%20Philippines%20blog/12.jpg" alt="Hébergement avec vue sur la mer à El Nido, Philippines" loading="lazy" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hébergement plusieurs mois à l'avance — El Nido est très prisée en haute saison (novembre–mai) et les meilleures adresses partent vite !</span>
                </p>
                <a href="https://www.booking.com/hotel/ph/mountain-villas-over-maramegmeg-beach-overlooking-bacuit-bay.fr.html" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à El Nido</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à El Nido&nbsp;?</em></h2>
                <p>El Nido s'adapte à tous les budgets — de l'hostel convivial au resort de luxe les pieds dans l'eau turquoise.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">20 – 35 €</div>
                    <div class="btr-val">50 – 100 €</div>
                    <div class="btr-val btr-val--luxe">150 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">5 – 10 €</div>
                    <div class="btr-val">15 – 25 €</div>
                    <div class="btr-val btr-val--luxe">40 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">2 – 5 €</div>
                    <div class="btr-val">10 – 15 €</div>
                    <div class="btr-val btr-val--luxe">25 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">10 – 25 €</div>
                    <div class="btr-val">30 – 70 €</div>
                    <div class="btr-val btr-val--luxe">100 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">500 – 1 000 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance pour les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à El Nido ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt ?? `${t.nom} à El Nido`} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à El Nido</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>El Nido,<br /><em>un paradis qui marque à vie</em></h2>
                <p>À El Nido, passe tes journées à explorer des lagons turquoise, des plages de sable blanc et des criques cachées entre des falaises calcaires à couper le souffle.</p>
                <p>Fais du snorkeling, pars en excursion vers les îles environnantes et profite des soirées animées d'El Nido Town. Entre aventures, détente et paysages inoubliables, chaque moment devient unique !</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/El%20Nido%20Philippines%20blog/1.jpg" />
                    <img src="/images/El%20Nido%20Philippines%20blog/4.jpg" alt="Vue panoramique sur les îles d'El Nido, Philippines" loading="lazy" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/El%20Nido%20Philippines%20blog/9.jpg" alt="Activités à El Nido entre amis, Philippines" loading="lazy" />
                    </div>
                    <a href="https://www.getyourguide.com/s/?q=el+nido+philippines&searchSource=3" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/El%20Nido%20Philippines%20blog/12.jpg" alt="Hébergement à El Nido, Philippines" loading="lazy" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=el+nido&dest_id=-2425520&dest_type=city" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/El%20Nido%20Philippines%20blog/10.jpg" alt="Transport aux Philippines depuis El Nido" loading="lazy" />
                    </div>
                    <a href="https://www.tkqlhce.com/click-101634807-17115158?url=https%3A%2F%2F12go.asia%2Fen%2Ftravel%2Fmanila%2Fel-nido" target="_blank" rel="noopener sponsored" class="cta-btn cta-btn--ghost">Déplace-toi partout aux Philippines</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/El%20Nido%20Philippines%20blog/18.jpg" alt="Vol pour El Nido aux Philippines" loading="lazy" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — El Nido entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

