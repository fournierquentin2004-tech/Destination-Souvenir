---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Explore Pig Island", desc: "Embarque pour une escapade vers l'île aux cochons, où tu pourras te balader sur une plage de rêve avec les cochons sauvages. Puis mets le cap sur une île aux eaux turquoise. Fais du snorkeling parmi les poissons tropicaux, détends-toi sur le sable blanc et déjeune face à la mer.", img: "/images/Koh%20Samui%20blog/1.jpg", imgMobile: "/images/Koh%20Samui%20blog/1.jpg", alt: "Pig Island et ses cochons sauvages sur la plage, Koh Samui, Thaïlande", lien: "https://www.getyourguide.com/fr-fr/koh-samui-l975/" },
    { titre: "Archipel tropical", desc: "Passe une journée au cœur d'un archipel magnifique. Nage parmi les poissons colorés, grimpe jusqu'à un point de vue sur le lac Émeraude et savoure un déjeuner sur la plage. Entre kayak et exploration de criques cachées, laisse-toi émerveiller par ces îles paradisiaques !", img: "/images/Koh%20Samui%20blog/1.jpg", alt: "Archipel d'Ang Thong et ses îles paradisiaques depuis Koh Samui, Thaïlande", lien: "https://www.getyourguide.com/fr-fr/koh-samui-l975/" },
    { titre: "Sanctuaire d'éléphants", desc: "Découvre un sanctuaire d'éléphants : prépare leur nourriture, nourris-les et accompagne-les dans leur bain de boue. Savoure ensuite un délicieux déjeuner tout en profitant d'un moment de détente. Une expérience unique au plus près de ces géants d'Asie.", img: "/images/Koh%20Samui%20blog/1.jpg", alt: "Sanctuaire d'éléphants à Koh Samui, Thaïlande", lien: "https://www.getyourguide.com/fr-fr/koh-samui-l975/" },
];

const hebergements = [
    { type: "Chaweng", ex: "Beach clubs, bars et hôtels en bord de mer", desc: "Le quartier le plus animé de Koh Samui. Parfait pour les fêtards et les amateurs de plage avec une vie nocturne intense, des restaurants variés et un accès direct aux plus belles plages de l'île.", tag: "Budget" },
    { type: "Lamai", ex: "Resorts, restaurants et ambiance détendue", desc: "Le bon équilibre entre détente et sorties. Moins agité que Chaweng mais tout aussi bien équipé. Idéal pour profiter des plages sans renoncer aux soirées et aux restaurants.", tag: "Équilibre" },
    { type: "Bophut (Fisherman's Village)", ex: "Boutique-hôtels, bars stylés et charme local", desc: "L'option chic et authentique. Un ancien village de pêcheurs transformé en quartier branché avec des restaurants gastronomiques, des bars tendance et une atmosphère romantique loin du tourisme de masse.", tag: "Luxe" },
];

const transports = [
    { nom: "Songthaew", desc: "Le moyen de transport local par excellence. Ce taxi collectif en forme de pick-up sillonne l'île à petit prix. Pratique, économique et convivial pour découvrir Koh Samui comme un local.", img: "/images/Koh%20Samui%20blog/1.jpg", alt: "Songthaew, taxi collectif local à Koh Samui, Thaïlande" },
    { nom: "Bateau", desc: "Indispensable pour les excursions vers les îles environnantes. Prends le ferry ou loue un bateau pour explorer l'archipel d'Ang Thong, Koh Phangan ou encore Koh Tao.", img: "/images/Koh%20Samui%20blog/1.jpg", alt: "Bateau pour les excursions en mer depuis Koh Samui, Thaïlande" },
    { nom: "Taxi / Grab", desc: "Simple, rapide et peu coûteux pour les trajets plus longs ou nocturnes. L'application Grab fonctionne très bien à Koh Samui et permet d'éviter les négociations de prix.", img: "/images/Koh%20Samui%20blog/1.jpg", alt: "Taxi ou Grab pour se déplacer à Koh Samui, Thaïlande" },
];

const conseils = [
    { titre: "Meilleure période", desc: "Janvier à août — 30°C en moyenne, ciel dégagé et mer calme. La période idéale pour profiter des plages et des excursions en mer." },
    { titre: "Période à éviter", desc: "Octobre à décembre : saison des pluies avec des précipitations fréquentes. Certaines activités en mer peuvent être annulées." },
    { titre: "Respect culturel", desc: "Tenue couvrant les épaules et les genoux obligatoire dans les temples. Retire tes chaussures avant d'entrer et adopte un comportement respectueux." },
    { titre: "Réserve à l'avance", desc: "Activités et hébergements se remplissent vite en haute saison. Réserve plusieurs semaines à l'avance pour éviter les déceptions." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire à Koh Samui entre amis ?", r: "Les incontournables : l'excursion à Pig Island pour nager avec les cochons sauvages, la journée dans l'archipel d'Ang Thong avec kayak et snorkeling, la visite d'un sanctuaire d'éléphants, et la vie nocturne animée de Chaweng Beach." },
    { q: "Où dormir à Koh Samui ?", r: "Chaweng pour l'animation et la proximité des plages et des bars. Lamai pour un bon équilibre entre détente et sorties. Bophut (Fisherman's Village) pour une ambiance chic et authentique loin du tourisme de masse." },
    { q: "Quand partir à Koh Samui ?", r: "La période idéale pour partir à Koh Samui est de janvier à août, avec des températures agréables autour de 30°C et un ciel dégagé, parfait pour profiter des plages et des excursions en mer." },
];

const similaires = [
    { titre: "Que faire à Koh Phi Phi entre amis", desc: "Eaux turquoise, plages de sable blanc et soirées les pieds dans le sable — Koh Phi Phi, c'est le paradis absolu.", img: "/images/Koh%20Phi%20Phi%20blog/5.jpg", href: "/que-faire-a-koh-phi-phi-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Chiang Mai entre amis", desc: "Temples dorés, jungle luxuriante et marchés nocturnes envoûtants — Chiang Mai est la perle du nord de la Thaïlande.", img: "/images/Koh%20Samui%20blog/1.jpg", href: "/que-faire-a-chiang-mai-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Bangkok entre amis", desc: "Tuk-tuk qui foncent, saveurs qui explosent, nuits sans fin — Bangkok se vit à mille à l'heure.", img: "/images/Bangkok%20blog/7.jpg", href: "/que-faire-a-bangkok-entre-amis-guide-et-bons-plans", tag: "Asie" },
];
---

<Layout
    title="Que faire à Koh Samui entre amis : guide et bons plans 2026"
    description="Pig Island, archipel d'Ang Thong, sanctuaire d'éléphants et beach clubs festifs. Découvre notre guide complet pour un séjour inoubliable à Koh Samui entre amis."
    ogImage="/images/Koh%20Samui%20blog/1.jpg"
    canonicalPath="/que-faire-a-koh-samui-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
>
    <link rel="preload" as="image" href="/images/Koh%20Samui%20blog/1.jpg" slot="head" />

    <!-- Schema Article -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Koh Samui entre amis : guide et bons plans 2026",
        "description": "Pig Island, archipel d'Ang Thong, sanctuaire d'éléphants et beach clubs festifs. Découvre notre guide complet pour un séjour inoubliable à Koh Samui entre amis.",
        "image": "https://destinationsouvenir.com/images/Koh%20Samui%20blog/1.jpg",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2026-06-13",
        "dateModified": "2026-06-13",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-koh-samui-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <!-- Schema FAQPage -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire à Koh Samui entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables : l'excursion à Pig Island pour nager avec les cochons sauvages, la journée dans l'archipel d'Ang Thong avec kayak et snorkeling, la visite d'un sanctuaire d'éléphants, et la vie nocturne animée de Chaweng Beach." } },
            { "@type": "Question", "name": "Où dormir à Koh Samui ?", "acceptedAnswer": { "@type": "Answer", "text": "Chaweng pour l'animation et la proximité des plages et des bars. Lamai pour un bon équilibre entre détente et sorties. Bophut (Fisherman's Village) pour une ambiance chic et authentique loin du tourisme de masse." } },
            { "@type": "Question", "name": "Quand partir à Koh Samui ?", "acceptedAnswer": { "@type": "Answer", "text": "La période idéale pour partir à Koh Samui est de janvier à août, avec des températures agréables autour de 30°C et un ciel dégagé, parfait pour profiter des plages et des excursions en mer." } }
        ]
    })}</script>

    <!-- Schema BreadcrumbList -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Asie", "item": "https://destinationsouvenir.com/asie" },
            { "@type": "ListItem", "position": 3, "name": "Koh Samui", "item": "https://destinationsouvenir.com/que-faire-a-koh-samui-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Asie &nbsp;·&nbsp; Thaïlande</p>
            <h1>Que faire à <em>Koh Samui</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Palmiers, plages de sable blanc et beach clubs festifs… Koh Samui, c'est <em>le parfait équilibre entre détente et fun.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Koh Samui entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <picture>
                                    {a.imgMobile && <source media="(max-width: 767px)" srcset={a.imgMobile} />}
                                    <img src={a.img} alt={a.alt} loading="eager" />
                                </picture>
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Plage de Chaweng et ses eaux turquoise, Koh Samui, Thaïlande" loading="eager" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Palmiers et sable blanc à Koh Samui, Thaïlande" loading="eager" />
            <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Coucher de soleil sur la mer à Koh Samui, Thaïlande" loading="eager" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Archipel d'Ang Thong depuis Koh Samui, Thaïlande" loading="eager" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Hébergement avec piscine à Koh Samui, Thaïlande" loading="eager" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Koh Samui ?</em></h2>
                <p class="logements-sub">De la vie nocturne intense de Chaweng au charme authentique de Bophut — le quartier que tu choisis change tout à ton séjour.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Hébergement avec piscine à Koh Samui, Thaïlande" loading="eager" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hébergement plusieurs mois à l'avance — Koh Samui est très prisée en haute saison (janvier–août) et les meilleures adresses partent vite !</span>
                </p>
                <a href="https://www.booking.com/searchresults.fr.html?ss=Koh+Samui&aid=2311236&lang=fr" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Koh Samui</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Koh Samui&nbsp;?</em></h2>
                <p>Koh Samui s'adapte à tous les budgets — de l'hostel convivial au resort de luxe les pieds dans l'eau.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">25 – 35 €</div>
                    <div class="btr-val">60 – 120 €</div>
                    <div class="btr-val btr-val--luxe">180 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">5 – 12 €</div>
                    <div class="btr-val">15 – 30 €</div>
                    <div class="btr-val btr-val--luxe">50 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">3 – 6 €</div>
                    <div class="btr-val">10 – 20 €</div>
                    <div class="btr-val btr-val--luxe">30 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">15 – 30 €</div>
                    <div class="btr-val">40 – 80 €</div>
                    <div class="btr-val btr-val--luxe">120 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">600 – 1 100 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance pour les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Koh Samui ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt ?? `${t.nom} à Koh Samui`} loading="eager" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à Koh Samui</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Koh Samui,<br /><em>un paradis qui marque à vie</em></h2>
                <p>Koh Samui est la destination parfaite pour un voyage entre potes. La journée, tu explores des îles paradisiaques et des spots incroyables.</p>
                <p>Le soir, tu profites des beach bars et de l'ambiance festive de Chaweng. Un équilibre parfait entre détente, aventure et fête. Impossible de s'ennuyer !</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Koh%20Samui%20blog/1.jpg" />
                    <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Vue panoramique sur les plages de Koh Samui, Thaïlande" loading="eager" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Activités à Koh Samui entre amis, Thaïlande" loading="eager" />
                    </div>
                    <a href="https://www.getyourguide.com/s/?q=koh+samui&searchSource=3" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Hébergement à Koh Samui, Thaïlande" loading="eager" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Koh+Samui&aid=2311236&lang=fr" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Transport en Thaïlande depuis Koh Samui" loading="eager" />
                    </div>
                    <a href="https://www.tkqlhce.com/click-101634807-17115158?url=https%3A%2F%2F12go.asia%2Fen%2Ftravel%2Fbangkok%2Fkoh-samui" target="_blank" rel="noopener sponsored" class="cta-btn cta-btn--ghost">Déplace-toi partout en Thaïlande</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Koh%20Samui%20blog/1.jpg" alt="Vol pour Koh Samui en Thaïlande" loading="eager" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — Koh Samui entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="eager" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

