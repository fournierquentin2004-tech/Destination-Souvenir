---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Dîner dans le ciel au-dessus de Dubrovnik", desc: "Suspend-toi à 40 mètres au-dessus du sol et dîne suspendu dans les airs avec vue panoramique sur la vieille ville et la mer Adriatique. L'expérience la plus dingue de Dubrovnik — insolite, spectaculaire et tellement mémorable que tu en parleras longtemps.", img: "/images/Dubrovnik%20blog/1.webp", alt: "Dîner dans le ciel au-dessus de Dubrovnik entre amis", lien: "https://www.getyourguide.com/fr-fr/dubrovnik-l513/diner-dans-le-ciel-dubrovnik-t765946/?ranking_uuid=4d5ba9d2-8268-4b5c-9b2b-5f29054b1fa2" },
    { titre: "Croisière aux îles Elaphites", desc: "Monte sur un bateau et explore l'archipel des Elaphites — trois îles authentiques, eaux cristallines et plages secrètes. Boissons à bord, déjeuner en option et une journée complète loin de la foule touristique. La meilleure façon de voir la Croatie depuis la mer.", img: "/images/Dubrovnik%20blog/2.webp", alt: "Croisière aux îles Elaphites depuis Dubrovnik", lien: "https://www.getyourguide.com/fr-fr/dubrovnik-l513/dubrovnik-croisiere-sur-l-ile-d-elaphite-avec-boissons-et-dejeuner-facultatif-t246722/?ranking_uuid=318204ba-7f66-4e0b-9eaa-c052f0641bf1" },
    { titre: "Excursion cascades de Kravica et Mostar", desc: "Une journée épique : plonge dans les bassins émeraude des cascades de Kravica, puis explore les ruelles envoûtantes de Mostar et son pont légendaire. Deux destinations de rêve en une seule excursion depuis Dubrovnik.", img: "/images/Dubrovnik%20blog/3.webp", alt: "Excursion cascades de Kravica et Mostar depuis Dubrovnik", lien: "https://www.getyourguide.com/fr-fr/mostar-l1334/dubrovnik-excursion-d-une-journee-aux-cascades-de-kravica-et-a-mostar-t402063/?ranking_uuid=318204ba-7f66-4e0b-9eaa-c052f0641bf1" },
];

const hebergements = [
    { type: "Vieille ville", ex: "Au cœur de l'histoire et de la fête", desc: "Dors à l'intérieur des remparts millénaires, à deux pas des bars et des restaurants. L'endroit le plus animé et le plus iconique de Dubrovnik — parfait pour un groupe qui veut sortir à pied toute la nuit.", tag: "Ambiance" },
    { type: "Lapad", ex: "Calme, plage et prix raisonnables", desc: "Le quartier résidentiel à l'ouest, plus calme et avec des hôtels bien plus abordables. Accès facile à la vieille ville en bus. Idéal pour les groupes qui veulent profiter de la plage sans payer le prix fort.", tag: "Calme" },
    { type: "Babin Kuk", ex: "Resorts en bord de mer", desc: "La presqu'île verte au nord-ouest de Dubrovnik, avec des resorts confortables directement en bord de mer. Idéal pour un séjour plus haut de gamme avec piscine et accès direct à la mer.", tag: "Confort" },
];

const transports = [
    { nom: "Bus locaux", desc: "Le réseau de bus de Dubrovnik est efficace et dessert tous les quartiers pour environ 2€ le trajet. Indispensable pour relier la vieille ville à Lapad ou Babin Kuk. Achète un pass journalier si tu te déplaces beaucoup.", img: "/images/Dubrovnik%20blog/6.webp" },
    { nom: "Bateau & ferry", desc: "La connexion maritime la plus pratique pour atteindre les îles Elaphites, Lokrum ou Hvar. Les ferries partent du port vieux (Stari Grad). Pour les excursions en groupe, réserve via GetYourGuide pour avoir un guide et la logistique inclus.", img: "/images/Dubrovnik%20blog/7.webp" },
    { nom: "Taxi & Uber", desc: "Uber fonctionne à Dubrovnik et reste la solution la plus simple pour les transferts aéroport ou les sorties nocturnes. Les taxis locaux sont également disponibles — négocie le prix à l'avance ou exige le compteur.", img: "/images/shared/cta-voiture-vtc.webp" },
];

const conseils = [
    { titre: "Période idéale", desc: "Mai-juin et sept-oct pour la météo et moins de foule. En été, arrive tôt le matin aux remparts." },
    { titre: "Réserve tout à l'avance", desc: "Hôtels, excursions et remparts se réservent des mois à l'avance — ne laisse rien au hasard." },
    { titre: "Remparts au coucher du soleil", desc: "La lumière dorée sur l'Adriatique et les toits orange vaut chaque euro du ticket d'entrée." },
    { titre: "Game of Thrones", desc: "Dubrovnik compte une dizaine de lieux de tournage GoT — un tour guidé spécial vaut le coup." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire à Dubrovnik entre amis ?", r: "Le dîner dans le ciel est l'expérience la plus unique de la ville. La croisière aux îles Elaphites est parfaite pour une journée en mer. Et l'excursion Kravica + Mostar te sort de Dubrovnik pour une journée de dépaysement total." },
    { q: "Quelle est la meilleure période pour visiter Dubrovnik ?", r: "Mai-juin et septembre-octobre sont idéaux : météo parfaite, mer chaude et beaucoup moins de monde que l'été. Juillet-août reste agréable mais la vieille ville peut être bondée — arrive tôt le matin pour profiter des remparts." },
    { q: "Quel quartier choisir pour dormir à Dubrovnik entre amis ?", r: "La vieille ville pour l'ambiance et la proximité des bars. Lapad pour les budgets serrés et la plage à portée. Babin Kuk pour le confort des resorts en bord de mer. Tout se fait en bus en quelques minutes." },
    { q: "Dubrovnik est-elle une bonne destination pour un groupe d'amis ?", r: "Absolument — c'est même l'une des plus belles destinations de Méditerranée pour un groupe. Remparts historiques, excursions en mer, dîner dans les hauteurs et bars animés dans la vieille ville. La Perle de l'Adriatique mérite amplement sa réputation." },
];

const similaires = [
    { titre: "Que faire à Split entre amis", desc: "Palais de Dioclétien, boat party mythique et plages dalmates dans la deuxième ville de Croatie.", img: "/images/Split%20blog/1.webp", href: "/que-faire-a-split-entre-amis-guide-et-bons-plans", tag: "Europe" },
    { titre: "Que faire à Budapest entre amis", desc: "Bains thermaux festifs, ruines bars underground et nuits épiques sur les bords du Danube.", img: "/images/2025/10/Budapest-a-deflouter-6-1.jpg", href: "/que-faire-a-budapest-entre-amis-guide-et-bons-plans", tag: "Europe" },
    { titre: "Où faire la fête à Amsterdam", desc: "Canaux romantiques, musées iconiques et nuits hollandaises qui ne finissent jamais.", img: "/images/2026/01/Amsterdam-1.jpg", href: "/ou-faire-la-fete-a-amsterdam", tag: "Europe" },
];
---

<Layout
    title="Que faire à Dubrovnik entre amis : guide et bons plans 2026"
    description="Remparts UNESCO, dîner dans le ciel et croisières vers les îles dalmates... Découvre tous les bons plans pour un séjour à Dubrovnik entre amis !"
    ogImage="/images/Dubrovnik%20blog/9.webp"
    canonicalPath="/que-faire-a-dubrovnik-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
    touristName="Dubrovnik"
    touristCountry="Croatie"
>
    <link rel="preload" as="image" href="/images/Dubrovnik%20blog/9.webp" slot="head" />

    <!-- Schema Article -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Dubrovnik entre amis : guide et bons plans 2026",
        "description": "Remparts UNESCO, dîner dans le ciel et croisières vers les îles dalmates... Découvre tous les bons plans pour un séjour à Dubrovnik entre amis !",
        "image": "https://destinationsouvenir.com/images/Dubrovnik%20blog/9.webp",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2025-11-20",
        "dateModified": "2026-06-23",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-dubrovnik-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <!-- Schema FAQPage -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire à Dubrovnik entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Le dîner dans le ciel est l'expérience la plus unique. La croisière aux îles Elaphites est parfaite pour une journée en mer. L'excursion Kravica + Mostar offre une journée de dépaysement total depuis Dubrovnik." } },
            { "@type": "Question", "name": "Quelle est la meilleure période pour visiter Dubrovnik ?", "acceptedAnswer": { "@type": "Answer", "text": "Mai-juin et septembre-octobre sont idéaux : météo parfaite, mer chaude et moins de foule. Juillet-août reste agréable mais la vieille ville peut être bondée." } },
            { "@type": "Question", "name": "Quel quartier choisir pour dormir à Dubrovnik entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "La vieille ville pour l'ambiance et la proximité des bars. Lapad pour les budgets serrés et la plage. Babin Kuk pour le confort des resorts en bord de mer." } },
            { "@type": "Question", "name": "Dubrovnik est-elle une bonne destination pour un groupe d'amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Absolument — remparts historiques, excursions en mer, dîner dans les hauteurs et bars animés. La Perle de l'Adriatique mérite amplement sa réputation pour les voyages entre amis." } }
        ]
    })}</script>

    <!-- Schema BreadcrumbList -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Europe", "item": "https://destinationsouvenir.com/voyager-en-europe" },
            { "@type": "ListItem", "position": 3, "name": "Dubrovnik", "item": "https://destinationsouvenir.com/que-faire-a-dubrovnik-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Europe &nbsp;·&nbsp; Croatie</p>
            <h1>Que faire à <em>Dubrovnik</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Dubrovnik, c'est King's Landing dans la vraie vie — remparts millénaires classés UNESCO, mer bleu profond à perte de vue et une énergie méditerranéenne qui envoûte dès le premier regard. <em>La destination croate la plus spectaculaire pour un groupe d'amis.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Dubrovnik entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <img src={a.img} alt={a.alt} loading="lazy" width="1280" height="720" />
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Dubrovnik%20blog/10.webp" alt="Vieille ville de Dubrovnik depuis la mer" loading="lazy" width="1280" height="720" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Dubrovnik%20blog/12.webp" alt="Port et côte de Dubrovnik" loading="lazy" width="1280" height="720" />
            <img src="/images/Dubrovnik%20blog/13.webp" alt="Vue aérienne sur l'île de Lokrum et Dubrovnik" loading="lazy" width="1280" height="720" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Dubrovnik%20blog/14.webp" alt="Côte dalmate et mer Adriatique près de Dubrovnik" loading="lazy" width="1280" height="720" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Dubrovnik%20blog/15.webp" alt="Vue sur un hébergement à Dubrovnik" loading="lazy" width="1280" height="720" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Dubrovnik ?</em></h2>
                <p class="logements-sub">Des remparts de la vieille ville aux resorts de Babin Kuk — chaque quartier de Dubrovnik a son ambiance. Trouve le spot parfait selon ton style et ton budget.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Dubrovnik%20blog/5.webp" alt="Vue sur un hébergement à Dubrovnik" loading="lazy" width="1280" height="720" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hébergement le plus tôt possible — Dubrovnik est l'une des destinations les plus prisées d'Europe. Les meilleurs hôtels partent des mois à l'avance en haute saison&nbsp;!</span>
                </p>
                <a href="https://www.booking.com/hotel/hr/san-rocco-palace.fr.html" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Voir l'hôtel recommandé</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Dubrovnik&nbsp;?</em></h2>
                <p>Un séjour à Dubrovnik est accessible si tu t'organises à l'avance. Les prix varient énormément selon la saison — mai et septembre offrent le meilleur rapport qualité-prix.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val">50 – 100 €</div>
                    <div class="btr-val btr-val--luxe">150 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">7 – 12 €</div>
                    <div class="btr-val">15 – 30 €</div>
                    <div class="btr-val btr-val--luxe">40 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">2 – 5 €</div>
                    <div class="btr-val">10 – 20 €</div>
                    <div class="btr-val btr-val--luxe">25 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">15 – 25 €</div>
                    <div class="btr-val">30 – 60 €</div>
                    <div class="btr-val btr-val--luxe">70 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">600 – 900 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> les vols Paris–Dubrovnik sont directs et souvent abordables en basse saison. Compare sur Skyscanner pour trouver les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Dubrovnik ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={`${t.nom} à Dubrovnik`} loading="lazy" width="1280" height="720" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour voyager à Dubrovnik entre amis</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Dubrovnik,<br /><em>la Perle de l'Adriatique</em></h2>
                <p>Il y a des villes qu'on visite et des villes qui marquent. Dubrovnik fait partie de la deuxième catégorie. Ses remparts surgissant de la mer, la lumière du soir sur les toits orange, la douceur de l'Adriatique — tout ici semble hors du temps.</p>
                <p>Entre amis, Dubrovnik prend une autre dimension. Les soirées dans la vieille ville, les excursions en bateau vers des îles désertes et le dîner suspendu dans les airs transforment le simple voyage en vrai souvenir.</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Dubrovnik%20blog/11.webp" />
                    <img src="/images/Dubrovnik%20blog/11.webp" alt="Vue aérienne sur Dubrovnik et la mer Adriatique" loading="lazy" width="1280" height="720" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Dubrovnik%20blog/2.webp" alt="Activités à Dubrovnik entre amis" loading="lazy" width="1280" height="720" />
                    </div>
                    <a href="https://www.getyourguide.com/fr-fr/dubrovnik-l513/" target="_blank" rel="noopener" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Dubrovnik%20blog/5.webp" alt="Hébergement à Dubrovnik" loading="lazy" width="1280" height="720" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Dubrovnik&lang=fr" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/shared/cta-vols.webp" alt="Vol pour Dubrovnik" loading="lazy" width="1920" height="1241" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — Dubrovnik entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" width="1280" height="720" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

