---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Découvre l'Opéra de Sydney", desc: "Explore l'Opéra de Sydney et plonge au cœur de ses halls majestueux. Découvre les secrets de ce chef-d'œuvre mondial et peut-être une répétition en coulisses. Une visite unique à ne pas manquer.", img: "/images/Sydney%20blog/2.jpg", alt: "Visite de l'Opéra de Sydney en Australie", lien: "https://www.getyourguide.com/fr-fr/sydney-l200/visite-de-l-opera-de-sydney-t28787/?ranking_uuid=78cfcea9-82d4-4215-808a-091a77b9442c" },
    { titre: "Excursion aux Blue Mountains", desc: "Pars à l'aventure dans les Blue Mountains et découvre l'un des paysages les plus spectaculaires d'Australie. Admire les cascades de Katoomba puis rencontre koalas et kangourous dans un décor splendide. Une escapade inoubliable.", img: "/images/Sydney%20blog/3.jpg", alt: "Paysage spectaculaire des Blue Mountains près de Sydney", lien: "https://www.getyourguide.com/fr-fr/sydney-l200/aventure-dans-les-blue-mountains-scenic-world-zoo-et-photo-avec-un-koala-t792241/?ranking_uuid=78cfcea9-82d4-4215-808a-091a77b9442c" },
    { titre: "Cours de surf à Bondi Beach", desc: "Initie-toi au surf à Bondi Beach et glisse sur tes premières vagues dans une ambiance fun et décontractée. Deux heures pour t'éclater, rire et pouvoir te vanter d'avoir dompté ce sport mythique sous le soleil australien.", img: "/images/Sydney%20blog/1.jpg", alt: "Cours de surf à Bondi Beach Sydney", lien: "https://www.getyourguide.com/fr-fr/sydney-l200/depuis-bondi-beach-2-heures-de-surf-pour-les-debutants-t25560/?ranking_uuid=78cfcea9-82d4-4215-808a-091a77b9442c" },
];

const hebergements = [
    { type: "CBD (Centre-ville)", ex: "Hôtels et appartements", desc: "Au cœur de l'action, à deux pas des restaurants, bars et sites touristiques. L'option idéale pour tout faire à pied et rentrer tard sans se ruiner en taxi.", tag: "Animé" },
    { type: "Surry Hills", ex: "Hôtels boutique et auberges", desc: "Branché, animé et plein de charme. Idéal pour les amateurs de cafés indépendants, de bars sympas et d'une ambiance locale authentique.", tag: "Branché" },
    { type: "Bondi Beach", ex: "Hôtels et résidences en bord de mer", desc: "Pour se réveiller les pieds dans le sable et enchaîner surf, baignade et brunch en terrasse. Le choix idéal pour profiter de la vie balnéaire.", tag: "Plage" },
];

const transports = [
    { nom: "Train / Métro / Bus", desc: "Le réseau Opal couvre toute la ville. Pratique pour rejoindre Bondi, Surry Hills, le CBD ou les quartiers excentrés à moindre coût.", img: "/images/Sydney%20blog/6.jpg", alt: "Transport en commun à Sydney, Australie" },
    { nom: "Ferry", desc: "La façon la plus agréable de se déplacer à Sydney. Indispensable pour rejoindre Manly, Watsons Bay ou Taronga Zoo avec une vue imprenable sur le port.", img: "/images/Sydney%20blog/5.jpg", alt: "Ferry sur le port de Sydney avec l'Opéra en arrière-plan" },
    { nom: "Taxi / Uber", desc: "Rapide et pratique pour rentrer tard le soir ou rejoindre des endroits mal desservis. Plus cher que les transports en commun mais confortable.", img: "/images/Sydney%20blog/18.jpg", alt: "Taxi dans les rues animées de Sydney" },
];

const conseils = [
    { titre: "Période idéale", desc: "Décembre à février (été australien) pour la chaleur, les plages et les festivals. Avril à juin offre aussi un temps doux et moins de monde — idéal pour les visites." },
    { titre: "Crème solaire", desc: "Le soleil australien est redoutable, même en automne. Protection SPF 50+ indispensable pour toutes les sorties à Bondi Beach ou en excursion." },
    { titre: "Night-club", desc: "La meilleure soirée de Sydney se passe tous les jeudis à l'Ivy Thursdays. Une adresse incontournable pour faire la fête comme un local." },
    { titre: "Réservation", desc: "Réserve tes activités (Opéra, Blue Mountains) et ton hébergement à l'avance, surtout en été australien (décembre-février) — les prix grimpent vite." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire à Sydney entre amis ?", r: "Les incontournables : visite de l'Opéra de Sydney, excursion aux Blue Mountains avec koalas et cascades, cours de surf à Bondi Beach, apéro vue sur le Harbour Bridge et soirées dans les rooftop bars de Surry Hills. Une ville où les plans ne manquent pas !" },
    { q: "Où dormir à Sydney ?", r: "Le CBD pour être au cœur de l'action, Surry Hills pour l'ambiance branchée et les bars, Bondi Beach pour profiter de la plage à volonté, ou Manly pour une atmosphère plus paisible en bord de mer." },
    { q: "Quelle est la période idéale pour aller à Sydney ?", r: "De décembre à février (été australien) pour profiter des plages et festivals en plein air. Avril à juin est aussi très agréable avec un temps plus doux et moins de touristes." },
];

const similaires = [
    { titre: "Que faire à Cairns entre amis", desc: "Plongée dans la Grande Barrière de Corail, vol en hélicoptère et plages tropicales — Cairns est le paradis australien de l'aventure.", img: "/images/Cairns%20blog/3.jpg", href: "/que-faire-a-cairns-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Bora Bora entre amis", desc: "Lagons turquoise, bungalows sur l'eau et couchers de soleil de rêve — Bora Bora incarne le paradis du Pacifique.", img: "/images/bora-bora-hero.jpg", href: "/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire aux Maldives entre amis", desc: "Sable blanc, eaux cristallines et vie marine à couper le souffle — les Maldives sont une destination de rêve absolu.", img: "/images/Maldives%20blog/1.jpg", href: "/que-faire-aux-maldives-entre-amis-guide-et-bons-plans", tag: "Océan Indien" },
];
---

<Layout
    title="Que faire à Sydney entre amis : guide et bons plans 2026"
    description="Surf à Bondi, visite de l'Opéra, soirées en boîte ou excursions dans les Blue Mountains : Sydney te réserve plein d'aventures !"
    ogImage="/images/Sydney%20blog/1.jpg"
    canonicalPath="/que-faire-a-sydney-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
>
    <link rel="preload" as="image" href="/images/Sydney%20blog/1.jpg" slot="head" />

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Sydney entre amis : guide et bons plans 2026",
        "description": "Surf à Bondi, visite de l'Opéra, soirées en boîte ou excursions dans les Blue Mountains : Sydney te réserve plein d'aventures !",
        "image": "https://destinationsouvenir.com/images/Sydney%20blog/1.jpg",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2025-11-10",
        "dateModified": "2026-06-08",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-sydney-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire à Sydney entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables : visite de l'Opéra de Sydney, excursion aux Blue Mountains, cours de surf à Bondi Beach, apéro vue sur le Harbour Bridge et soirées dans les rooftop bars de Surry Hills." } },
            { "@type": "Question", "name": "Où dormir à Sydney ?", "acceptedAnswer": { "@type": "Answer", "text": "Le CBD pour être au cœur de l'action, Surry Hills pour l'ambiance branchée et les bars, Bondi Beach pour la plage, ou Manly pour une atmosphère plus paisible en bord de mer." } },
            { "@type": "Question", "name": "Quelle est la période idéale pour aller à Sydney ?", "acceptedAnswer": { "@type": "Answer", "text": "De décembre à février (été australien) pour profiter des plages et festivals. Avril à juin est aussi très agréable avec un temps doux et moins de touristes." } }
        ]
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Océanie", "item": "https://destinationsouvenir.com/oceanie" },
            { "@type": "ListItem", "position": 3, "name": "Sydney", "item": "https://destinationsouvenir.com/que-faire-a-sydney-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Océanie &nbsp;·&nbsp; Sydney</p>
            <h1>Que faire à <em>Sydney</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Après de longues heures de vol, tu poses enfin le pied à Sydney. Le soleil, l'air marin, l'énergie de la ville… tout annonce le début d'une aventure incroyable entre amis.</p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Sydney entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <img src={a.img} alt={a.alt} loading="lazy" />
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">Découvrir l'activité</a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Sydney%20blog/9.jpg" alt="Vue panoramique du port de Sydney avec le Harbour Bridge" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Sydney%20blog/7.jpg" alt="Bondi Beach et ses vagues sous le soleil australien" loading="lazy" />
            <img src="/images/Sydney%20blog/10.jpg" alt="Skyline de Sydney au coucher du soleil" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Sydney%20blog/12.jpg" alt="Quartier animé de Surry Hills à Sydney" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Sydney%20blog/4.jpg" alt="Hébergement avec vue sur le port de Sydney" loading="lazy" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Sydney ?</em></h2>
                <p class="logements-sub">Du CBD animé aux plages de Bondi en passant par le quartier branché de Surry Hills — chaque coin de Sydney a son ambiance.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Sydney%20blog/4.jpg" alt="Hébergement avec vue sur le port de Sydney" loading="lazy" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve plusieurs mois à l'avance pour l'été australien (décembre-février) — Sydney est très prisée et les prix s'envolent rapidement&nbsp;!</span>
                </p>
                <a href="https://www.booking.com/hotel/au/intercontinental-sydney.fr.html?aid=2311236&label=fr-fr-booking-desktop-DCpBIW3k2%2AWIo8XuzMdB9AS652796013276%3Apl%3Ata%3Ap1%3Ap2%3Aac%3Aap%3Aneg%3Afi%3Atikwd-65526620%3Alp9056583%3Ali%3Adec%3Adm&sid=8c01b89ff726d3b7cb358c360dc7e62f&all_sr_blocks=17936208_366938806_2_2_0&checkin=2025-11-23&checkout=2025-11-24&dest_id=-1603135&dest_type=city&dist=0&group_adults=2&group_children=0&hapos=2&highlighted_blocks=17936208_366938806_2_2_0&hpos=2&matching_block_id=17936208_366938806_2_2_0&no_rooms=1&req_adults=2&req_children=0&room1=A%2CA&sb_price_type=total&sr_order=popularity&sr_pri_blocks=17936208_366938806_2_2_0__37900&srepoch=1763919067&srpvid=3f977b26f97703dd&type=total&ucfs=1" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Sydney</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Sydney&nbsp;?</em></h2>
                <p>Sydney est l'une des villes les plus chères d'Australie — mais les expériences valent largement l'investissement.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">30 – 60 €</div>
                    <div class="btr-val">80 – 150 €</div>
                    <div class="btr-val btr-val--luxe">200 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">10 – 20 €</div>
                    <div class="btr-val">25 – 45 €</div>
                    <div class="btr-val btr-val--luxe">60 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">5 – 10 €</div>
                    <div class="btr-val">15 – 25 €</div>
                    <div class="btr-val btr-val--luxe">40 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">15 – 30 €</div>
                    <div class="btr-val">40 – 70 €</div>
                    <div class="btr-val btr-val--luxe">100 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">900 – 1 200 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance pour les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Sydney ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à Sydney</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Sydney,<br /><em>nature et ville réunies</em></h2>
                <p>Sydney allie nature et ville comme nulle part ailleurs : plages magnifiques, panoramas à couper le souffle depuis le Harbour Bridge, culture vivante à l'Opéra et quartiers animés à explorer sans fin.</p>
                <p>Chaque coin de la ville promet des expériences uniques et inoubliables — une destination qui ne laisse jamais indifférent.</p>
            </div>
            <div class="conclusion-img-wrap">
                <img src="/images/Sydney%20blog/13.jpg" alt="Vue iconique sur l'Opéra et le Harbour Bridge de Sydney au coucher du soleil" loading="lazy" />
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Sydney%20blog/19.jpg" alt="Activités à Sydney, visite de l'Opéra" loading="lazy" />
                    </div>
                    <a href="https://www.getyourguide.com/fr-fr/sydney-l200/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Sydney%20blog/4.jpg" alt="Hébergement à Sydney, Australie" loading="lazy" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=sydney&ssne=Cairns&ssne_untouched=Cairns&label=fr-fr-booking-desktop-DCpBIW3k2*WIo8XuzMdB9AS652796013276%3Apl%3Ata%3Ap1%3Ap2%3Aac%3Aap%3Aneg%3Afi%3Atikwd-65526620%3Alp9195582%3Ali%3Adec%3Adm&sid=8c01b89ff726d3b7cb358c360dc7e62f&aid=2311236&lang=fr&sb=1&src_elem=sb&src=index&dest_id=-1603135&dest_type=city&ac_position=0&ac_click_type=b&ac_langcode=fr&ac_suggestion_list_length=5&search_selected=true&search_pageview_id=ed218648523402b3&ac_meta=GhBlZDIxODY0ODUyMzQwMmIzIAAoATICZnI6BnN5ZG5leQ%3D%3D&group_adults=2&no_rooms=1&group_children=0" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Sydney%20blog/20.jpg" alt="Vol pour Sydney, Australie" loading="lazy" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — Sydney entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => { if (other !== item) (other as HTMLDetailsElement).open = false; });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

