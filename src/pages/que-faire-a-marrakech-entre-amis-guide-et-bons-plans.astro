---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Dîner sous les étoiles dans le désert d'Agafay", desc: "Pars à la découverte du désert d'Agafay. Monte sur un chameau, savoure un thé marocain au coucher du soleil, découvre les collines dorées et les villages berbères, puis termine la soirée avec un dîner traditionnel et un spectacle envoûtant autour du feu.", img: "/images/Marrakech%20blog/9.webp", alt: "Dîner traditionnel sous les étoiles dans le désert d'Agafay près de Marrakech", lien: "https://www.getyourguide.com/fr-fr/prefecture-de-marrakech-l208/diner-sous-les-etoiles-dans-le-desert-d-agafay-coucher-de-soleil-a-dos-de-chameau-t477070/?ranking_uuid=4ba5139c-38a1-4c9f-92b6-0dc5e6463b84" },
    { titre: "Excursion dans la vallée de l'Ourika", desc: "Explore la vallée de l'Ourika et les montagnes de l'Atlas. Admire les villages berbères, les collines rouges et les oliveraies, puis profite d'une balade jusqu'aux cascades de Setti Fatma pour un moment de calme et de nature. Prépare-toi à en prendre plein les yeux !", img: "/images/Marrakech%20blog/3.webp", alt: "Vallée de l'Ourika avec cascades et montagnes de l'Atlas près de Marrakech", lien: "https://www.getyourguide.com/fr-fr/marrakech-l208/marrakech-dejeuner-dans-la-vallee-de-l-ourika-et-randonnee-guidee-jusqu-aux-cascades-t480657/?ranking_uuid=279a9048-215b-4d06-a3b0-8d2471580058&q=Setti%20Fadma" },
    { titre: "Voyage au cœur des dunes de Merzouga", desc: "Embarque pendant trois jours pour un voyage d'exception : traverse les montagnes de l'Atlas, pars à dos de chameau dans les dunes dorées de Merzouga, admire un coucher de soleil à couper le souffle, dors sous un ciel étoilé et réveille-toi avec le lever du soleil sur le désert.", img: "/images/Marrakech%20blog/4.webp", alt: "Dunes de Merzouga au coucher du soleil lors d'un voyage en 3 jours depuis Marrakech", lien: "https://www.getyourguide.com/fr-fr/prefecture-de-marrakech-l208/de-marrakech-a-merzouga-3-jours-d-aventure-dans-le-desert-t482521/?ranking_uuid=4ba5139c-38a1-4c9f-92b6-0dc5e6463b84" },
];

const hebergements = [
    { type: "La Médina", ex: "Ruelles vivantes, souks, riads et immersion totale", desc: "Le cœur authentique de Marrakech classé au patrimoine mondial de l'UNESCO. Ruelles labyrinthiques, souks colorés et riads traditionnels — la Médina, c'est l'expérience marocaine dans toute sa splendeur. Parfait pour un groupe qui veut s'immerger dans la culture locale et être à pied de tout.", tag: "Immersion" },
    { type: "Guéliz", ex: "Moderne, restaurants, cafés et boutiques branchées", desc: "Le quartier européen et moderne de Marrakech. Cafés tendance, restaurants gastronomiques, galeries d'art et boutiques branchées — Guéliz offre une ambiance cosmopolite parfaite pour un groupe qui veut profiter du meilleur des deux mondes, à quelques minutes de la Médina.", tag: "Moderne" },
    { type: "Hivernage & Palmeraie", ex: "Hôtels de luxe, clubs, rooftops et nightlife chic", desc: "Pour les groupes en quête de fête et de luxe. Hivernage concentre les clubs les plus branchés, les rooftops et les hôtels haut de gamme. La Palmeraie offre calme, nature et villas avec piscine pour ceux qui veulent une ambiance resort exclusive loin de l'agitation de la ville.", tag: "Luxe" },
];

const transports = [
    { nom: "Petit taxi & grand taxi", desc: "Les petits taxis rouges circulent dans Marrakech pour les trajets courts — négocie toujours le prix avant de monter. Les grands taxis beige relient Marrakech aux destinations alentours comme Essaouira ou Ourika. Pratiques, abordables et disponibles partout dans la ville.", img: "/images/Marrakech%20blog/7.webp", alt: "Taxis rouges dans les rues de Marrakech pour se déplacer facilement" },
    { nom: "Location de voiture", desc: "Idéal pour explorer le désert d'Agafay, les cascades d'Ouzoud ou les montagnes de l'Atlas à ton rythme. Loue ta voiture directement à l'aéroport Marrakech-Ménara et profite de la liberté totale pour découvrir les paysages marocains sans contrainte de planning.", img: "/images/shared/cta-location-voiture.webp", alt: "Location de voiture à Marrakech pour explorer l'Atlas et le désert librement" },
    { nom: "À pied", desc: "C'est le meilleur moyen de découvrir la Médina. Les ruelles de la vieille ville sont trop étroites pour les voitures — perds-toi volontairement dans les souks, suis les odeurs d'épices, et laisse-toi surprendre par chaque recoin. La Médina se vit à pied, sans GPS et sans heure.", img: "/images/Marrakech%20blog/6.webp", alt: "Balade à pied dans les ruelles et souks de la Médina de Marrakech" },
];

const conseils = [
    { titre: "Période idéale", desc: "Mars–mai et sept–nov : 20–28 °C. Évite juillet–août (40 °C+) et les week-ends de l'Aïd." },
    { titre: "Négociation", desc: "Dans les souks, commence à 30–40 % du prix affiché. Ne montre pas ton enthousiasme, sois prêt à partir." },
    { titre: "Arnaques à éviter", desc: "Refuse les 'guides' non officiels dans les souks — ils touchent des commissions. Reste ferme et décline poliment." },
    { titre: "Monnaie & budget", desc: "Le dirham ne se change pas hors du Maroc. Emporte des euros et prévois du cash pour les souks et restaurants locaux." },
];

const faq = [
    { q: "Quelle est la meilleure période pour aller à Marrakech ?", r: "Mars à mai et septembre à novembre offrent les températures les plus agréables (20–28 °C) et les meilleures conditions pour explorer la ville et faire des excursions. Évite juillet–août où il fait 40 °C+ et les foules de la haute saison estivale." },
    { q: "Quelles sont les meilleures activités à Marrakech entre amis ?", r: "Les incontournables de Marrakech : dîner sous les étoiles dans le désert d'Agafay avec balade à dos de chameau, excursion dans la vallée de l'Ourika et les cascades de Setti Fatma, soirée dans les clubs d'Hivernage, exploration des souks de la Médina et hammam traditionnel." },
    { q: "Où dormir à Marrakech entre amis ?", r: "La Médina pour l'immersion totale dans les riads traditionnels, Guéliz pour le confort moderne et les restaurants tendance, Hivernage pour la nightlife et les hôtels de luxe, la Palmeraie pour une ambiance villa avec piscine. Le choix dépend de l'ambiance que tu recherches !" },
];

const similaires = [
    { titre: "Que faire à Zanzibar entre amis", desc: "Plages paradisiaques, dauphins à Mnemba et safari au parc de Mikumi — Zanzibar, l'île aux épices de l'océan Indien.", img: "/images/Zanzibar%20blog/10.webp", href: "/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans", tag: "Afrique" },
    { titre: "Que faire à Bali entre amis", desc: "Rizières en terrasses, temples mystérieux et nuits festives à Seminyak — Bali, l'île des dieux qui envoûte tous les voyageurs.", img: "/images/Bali%20blog/1.webp", href: "/que-faire-a-bali-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Rio de Janeiro entre amis", desc: "Christ Rédempteur, favela Rocinha et plages de Copacabana — Rio, la ville la plus intense du monde qui te prend par les tripes.", img: "/images/Rio%20de%20Janeiro%20blog/1.webp", href: "/que-faire-a-rio-de-janeiro-entre-amis-guide-et-bons-plans", tag: "Amérique" },
];
---

<Layout
    title="Que faire à Marrakech entre amis : guide et bons plans 2026"
    description="Désert d'Agafay, vallée de l'Ourika et dunes de Merzouga : notre guide complet pour préparer ton séjour à Marrakech entre amis au Maroc."
    ogImage="/images/Marrakech%20blog/1.webp"
    canonicalPath="/que-faire-a-marrakech-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
    touristName="Marrakech"
    touristCountry="Maroc"
>
    <link rel="preload" as="image" href="/images/Marrakech%20blog/1.webp" slot="head" />

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Marrakech entre amis : guide et bons plans 2026",
        "description": "Désert d'Agafay, vallée de l'Ourika et dunes de Merzouga : notre guide complet pour préparer ton séjour à Marrakech entre amis au Maroc.",
        "image": "https://destinationsouvenir.com/images/Marrakech%20blog/1.webp",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2026-06-15",
        "dateModified": "2026-06-15",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-marrakech-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelle est la meilleure période pour aller à Marrakech ?", "acceptedAnswer": { "@type": "Answer", "text": "Mars à mai et septembre à novembre offrent les températures les plus agréables (20–28 °C) et les meilleures conditions pour explorer la ville et faire des excursions. Évite juillet–août où il fait 40 °C+ et les foules de la haute saison estivale." } },
            { "@type": "Question", "name": "Quelles sont les meilleures activités à Marrakech entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables de Marrakech : dîner sous les étoiles dans le désert d'Agafay avec balade à dos de chameau, excursion dans la vallée de l'Ourika et les cascades de Setti Fatma, soirée dans les clubs d'Hivernage, exploration des souks de la Médina et hammam traditionnel." } },
            { "@type": "Question", "name": "Où dormir à Marrakech entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "La Médina pour l'immersion totale dans les riads traditionnels, Guéliz pour le confort moderne et les restaurants tendance, Hivernage pour la nightlife et les hôtels de luxe, la Palmeraie pour une ambiance villa avec piscine." } }
        ]
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Afrique", "item": "https://destinationsouvenir.com/afrique" },
            { "@type": "ListItem", "position": 3, "name": "Marrakech", "item": "https://destinationsouvenir.com/que-faire-a-marrakech-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Afrique &nbsp;·&nbsp; Maroc</p>
            <h1>Que faire à <em>Marrakech</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Souks envoûtants, désert d'Agafay et nuits festives… Marrakech, c'est <em>la ville ocre qui t'envoûte pour toujours.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Marrakech entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <picture>
                                    <img src={a.img} alt={a.alt} loading="lazy" />
                                </picture>
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Marrakech%20blog/23.webp" alt="Souks colorés et artisanat de la Médina de Marrakech" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Marrakech%20blog/11.webp" alt="Ambiance festive à Marrakech avec vue sur la ville ocre" loading="lazy" />
            <img src="/images/Marrakech%20blog/25.webp" alt="Architecture traditionnelle marocaine au cœur de Marrakech" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Marrakech%20blog/20.webp" alt="Panorama sur les toits ocre de la Médina de Marrakech" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Marrakech%20blog/21.webp" alt="Riad de luxe avec piscine à Marrakech au Maroc" loading="lazy" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Marrakech ?</em></h2>
                <p class="logements-sub">De la Médina authentique aux hôtels de luxe d'Hivernage — le quartier que tu choisis définit complètement l'ambiance de ton séjour à Marrakech.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Marrakech%20blog/21.webp" alt="Riad de luxe avec piscine à Marrakech au Maroc" loading="lazy" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hébergement plusieurs mois à l'avance pour profiter des meilleures offres, surtout en haute saison (mars–mai et sept–nov) où les riads de la Médina affichent complet très tôt !</span>
                </p>
                <a href="https://www.booking.com/hotel/ma/du-tresor.fr.html" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Marrakech</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Marrakech&nbsp;?</em></h2>
                <p>Marrakech est l'une des destinations les plus accessibles — des riads économiques aux palaces de luxe, il y en a pour tous les budgets.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">10 – 30 €</div>
                    <div class="btr-val">40 – 100 €</div>
                    <div class="btr-val btr-val--luxe">150 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">5 – 12 €</div>
                    <div class="btr-val">12 – 25 €</div>
                    <div class="btr-val btr-val--luxe">40 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">1 – 4 €</div>
                    <div class="btr-val">4 – 10 €</div>
                    <div class="btr-val btr-val--luxe">20 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">15 – 40 €</div>
                    <div class="btr-val">40 – 80 €</div>
                    <div class="btr-val btr-val--luxe">100 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">350 – 700 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> des vols directs relient Paris à Marrakech toute l'année en moins de 3h30. Réserve 2 à 4 mois à l'avance pour les meilleurs tarifs — les prix peuvent doubler en haute saison !</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Marrakech ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à Marrakech</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Marrakech entre amis,<br /><em>la ville qui t'envoûte</em></h2>
                <p>Marrakech est une destination parfaite entre amis : souks enivrants, hammams traditionnels, dîner sous les étoiles dans le désert, nuits festives à Hivernage et excursions grandioses dans l'Atlas ou le Sahara.</p>
                <p>Que tu sois plutôt culture, aventure ou fête, Marrakech offre le mélange idéal pour créer des souvenirs inoubliables. La ville ocre de l'Atlas t'attend — tu n'auras plus envie de repartir !</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Marrakech%20blog/19.webp" />
                    <img src="/images/Marrakech%20blog/19.webp" alt="Coucher de soleil sur les toits ocre de la Médina de Marrakech" loading="lazy" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement, tes vols et ta voiture au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Marrakech%20blog/8.webp" alt="Excursions et activités incontournables à Marrakech avec GetYourGuide" loading="lazy" />
                    </div>
                    <a href="https://www.getyourguide.com/fr-fr/marrakech-l208/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Marrakech%20blog/5.webp" alt="Riad et hôtels à Marrakech, réservation sur Booking" loading="lazy" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Marrakech" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/shared/cta-location-voiture.webp" alt="Location de voiture à Marrakech pour explorer le Maroc avec Sixt" loading="lazy" />
                    </div>
