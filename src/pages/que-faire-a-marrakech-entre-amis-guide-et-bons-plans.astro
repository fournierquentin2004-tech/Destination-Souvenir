<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = Math.max(0, Math.min(index, cards.length - 1));
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = Math.max(0, Math.min(index, simCards.length - 1));
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

