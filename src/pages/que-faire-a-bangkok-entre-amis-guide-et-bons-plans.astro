---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Combat de Muay Thai", desc: "Plonge dans l'ambiance électrique d'un stade de Muay Thai à Bangkok. Les tambours résonnent, les spectateurs acclament, et chaque coup porté par les boxeurs te fait vibrer d'adrénaline. Une tradition thaïlandaise spectaculaire, intense et inoubliable.", img: "/images/Bangkok%20blog/4.jpg", alt: "Combat de Muay Thai au stade Rajadamnern à Bangkok", lien: "https://www.getyourguide.com/fr-fr/bangkok-l169/bangkok-billets-pour-la-boxe-muay-thai-au-stade-rajadamnern-t505196/?ranking_uuid=065aa56a-d35a-49cc-87a4-20def0f7762e" },
    { titre: "Marché flottant de Damnoen Saduak", desc: "Les marchés flottants s'animent dès l'aube, avec des barques colorées, des odeurs de fruits tropicaux et d'épices qui envahissent l'air. Monte dans une barque, goûte les spécialités et laisse-toi porter par l'ambiance unique de Damnoen Saduak.", img: "/images/Bangkok%20blog/1.jpg", alt: "Marché flottant de Damnoen Saduak à Bangkok", lien: "https://www.getyourguide.com/fr-fr/bangkok-l169/bangkok-marche-de-damnoen-saduak-et-marche-ferroviaire-de-maeklong-t383872/?ranking_uuid=065aa56a-d35a-49cc-87a4-20def0f7762e" },
    { titre: "Visite des temples historiques", desc: "Ces temples sont des joyaux architecturaux et culturels. Admire le Bouddha couché de Wat Pho, laisse-toi éblouir par les dorures du Grand Palais et assiste au coucher de soleil sur le Wat Arun depuis la rivière Chao Phraya.", img: "/images/Bangkok%20blog/2.jpg", alt: "Grand Palais et temple Wat Pho à Bangkok", lien: "https://www.getyourguide.com/fr-fr/bangkok-l169/bangkok-visite-guidee-du-grand-palais-du-wat-pho-et-du-wat-arun-t840436/?ranking_uuid=065aa56a-d35a-49cc-87a4-20def0f7762e" },
];

const hebergements = [
    { type: "Khao San Road", ex: "Hostels et guesthouses animées", desc: "Parfait si tu cherches la fête, les bars et l'ambiance backpacker. Le quartier le plus connu des voyageurs du monde entier.", tag: "Budget" },
    { type: "Sukhumvit", ex: "Hôtels boutique et résidences", desc: "Le mix idéal entre vie nocturne, bons restaurants et centres commerciaux. Pratique et ultra-bien desservi par le BTS.", tag: "Équilibre" },
    { type: "Riverside", ex: "Hôtels de luxe avec vue sur la Chao Phraya", desc: "Pour une expérience plus calme avec vue sur la rivière. Hôtels iconiques, spas et couchers de soleil inoubliables.", tag: "Luxe" },
];

const transports = [
    { nom: "Tuk-tuk", desc: "L'expérience typique de Bangkok. Mythique et amusant, mais n'oublie pas de négocier le prix avant de monter !", img: "/images/Bangkok%20blog/9.jpg" },
    { nom: "BTS Skytrain & MRT", desc: "Rapides, climatisés et économiques. Le meilleur moyen d'éviter les embouteillages légendaires de Bangkok.", img: "/images/Bangkok%20blog/10.jpg" },
    { nom: "Grab", desc: "Pratique et sécurisé, l'équivalent thaïlandais d'Uber. Prix fixes, pas de négociation — indispensable en groupe.", img: "/images/Bangkok%20blog/11.jpg" },
];

const conseils = [
    { titre: "Assurance voyage", desc: "Indispensable en Thaïlande. Les frais médicaux peuvent vite grimper — mieux vaut partir l'esprit tranquille." },
    { titre: "Meilleure période", desc: "Novembre à février — températures agréables (25–30°C), loin de la saison des pluies." },
    { titre: "Culture & temples", desc: "Respecte les traditions : couvre épaules et genoux pour entrer dans les temples." },
    { titre: "Planifie les activités", desc: "Réserve Muay Thai et marchés flottants à l'avance — les meilleures places partent vite." },
];

const faq = [
    { q: "Quelle est la meilleure période pour aller à Bangkok entre amis ?", r: "De novembre à février, les températures sont agréables (25–30°C) et tu échappes à la saison des pluies. C'est la haute saison, idéale pour profiter des temples, marchés et nuits animées." },
    { q: "Quelles sont les meilleures activités à faire à Bangkok entre amis ?", r: "Les incontournables : assister à un combat de Muay Thai au stade Rajadamnern, explorer les marchés flottants de Damnoen Saduak, visiter le Grand Palais et Wat Pho, faire une croisière sur la Chao Phraya la nuit, et terminer sur un rooftop avec vue panoramique." },
    { q: "Pourquoi souscrire à une assurance voyage pour Bangkok ?", r: "Une assurance voyage te couvre en cas de pépin. En Thaïlande, les frais médicaux peuvent vite grimper — mieux vaut partir l'esprit tranquille et profiter à fond sans s'inquiéter." },
];

const similaires = [
    { titre: "Que faire à Bali entre amis", desc: "Plages paradisiaques, rizières à perte de vue, temples mystiques et soirées animées dans l'île des dieux.", img: "/images/Bali%20blog/17.jpg", href: "/que-faire-a-bali-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Koh Phi Phi entre amis", desc: "Falaises de calcaire, lagons secrets et fêtes sur la plage dans les îles thaïlandaises les plus spectaculaires.", img: "/images/2026/01/Koh-Phi-Phi-Thailand-Blog-1.jpg", href: "/que-faire-a-koh-phi-phi-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire aux Maldives entre amis", desc: "Lagons turquoise, bungalows sur pilotis et snorkeling dans les eaux les plus claires du monde.", img: "/images/2026/01/Maldives-blog.jpg", href: "/que-faire-aux-maldives-entre-amis-guide-et-bons-plans", tag: "Asie" },
];
---

<Layout
    title="Que faire à Bangkok entre amis : guide et bons plans 2026"
    description="Temples, rooftops, marchés flottants et nuits sans fin. Découvre notre guide complet pour un séjour inoubliable à Bangkok entre amis — activités, hébergement et budget."
    ogImage="/images/Bangkok%20blog/7.jpg"
    canonicalPath="/que-faire-a-bangkok-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
>
    <link rel="preload" as="image" href="/images/Bangkok%20blog/7.jpg" slot="head" />

    <!-- Schema Article -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Bangkok entre amis : guide et bons plans 2026",
        "description": "Temples, rooftops, marchés flottants et nuits sans fin. Découvre notre guide complet pour un séjour inoubliable à Bangkok entre amis — activités, hébergement et budget.",
        "image": "https://destinationsouvenir.com/images/Bangkok%20blog/7.jpg",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2025-10-04",
        "dateModified": "2026-06-07",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-bangkok-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <!-- Schema FAQPage -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelle est la meilleure période pour aller à Bangkok entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "De novembre à février, les températures sont agréables (25–30°C) et tu échappes à la saison des pluies. C'est la haute saison, idéale pour profiter des temples, marchés et nuits animées." } },
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire à Bangkok entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables : assister à un combat de Muay Thai, explorer les marchés flottants de Damnoen Saduak, visiter le Grand Palais et Wat Pho, faire une croisière sur la Chao Phraya la nuit, et terminer sur un rooftop avec vue panoramique." } },
            { "@type": "Question", "name": "Pourquoi souscrire à une assurance voyage pour Bangkok ?", "acceptedAnswer": { "@type": "Answer", "text": "Une assurance voyage te couvre en cas de pépin. En Thaïlande, les frais médicaux peuvent vite grimper — mieux vaut partir l'esprit tranquille." } }
        ]
    })}</script>

    <!-- Schema BreadcrumbList -->
    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Asie", "item": "https://destinationsouvenir.com/asie" },
            { "@type": "ListItem", "position": 3, "name": "Bangkok", "item": "https://destinationsouvenir.com/que-faire-a-bangkok-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Asie &nbsp;·&nbsp; Bangkok</p>
            <h1>Que faire à <em>Bangkok</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Oublie les vacances tranquilles&nbsp;: Bangkok se vit à mille à l'heure. Des tuk-tuk qui foncent, des saveurs qui explosent, des nuits sans fin — ici, tout va plus vite, plus fort, <em>plus vrai.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Bangkok entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <img src={a.img} alt={a.alt} loading="lazy" />
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Bangkok%20blog/12.jpg" alt="Temple doré à Bangkok" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Bangkok%20blog/17.jpg" alt="Barque royale thaïlandaise dorée et fleurs colorées à Bangkok" loading="lazy" />
            <img src="/images/Bangkok%20blog/13.jpg" alt="Gardiens du Grand Palais de Bangkok" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Bangkok%20blog/6.jpg" alt="Wat Arun au coucher de soleil à Bangkok" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Bangkok%20blog/8.jpg" alt="Rooftop piscine infinity à Bangkok" loading="lazy" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Bangkok ?</em></h2>
                <p class="logements-sub">De l'ambiance backpacker de Khao San Road aux hôtels de luxe sur la Chao Phraya — où dormir à Bangkok selon ton budget.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Bangkok%20blog/8.jpg" alt="Rooftop piscine infinity à Bangkok" loading="lazy" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hôtel plusieurs mois à l'avance pour profiter des meilleures offres — surtout en haute saison (novembre–février)&nbsp;!</span>
                </p>
                <a href="https://www.booking.com/hotel/th/travelodge-sukhumvit-11.fr.html?aid=2311236&label=fr-fr-booking-desktop-DCpBIW3k2%2AWIo8XuzMdB9AS652796013276%3Apl%3Ata%3Ap1%3Ap2%3Aac%3Aap%3Aneg%3Afi%3Atikwd-65526620%3Alp9056132%3Ali%3Adec%3Adm&sid=8c01b89ff726d3b7cb358c360dc7e62f&all_sr_blocks=0_0_4_0_0&checkin=2025-11-19&checkout=2025-11-22&dest_id=-3414440&dest_type=city&dist=0&group_adults=4&group_children=0&hapos=3&highlighted_blocks=0_0_4_0_0&hpos=3&matching_block_id=0_0_4_0_0&no_rooms=1&req_adults=4&req_children=0&room1=A%2CA%2CA%2CA&sb_price_type=total&sr_order=popularity&sr_pri_blocks=0_0_4_0_0__1166807&srepoch=1760109796&srpvid=252c6c2b38a20730&type=total&ucfs=1&" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Bangkok</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Bangkok&nbsp;?</em></h2>
                <p>Bangkok est l'une des capitales les plus abordables d'Asie — idéal pour voyager en groupe sans se ruiner.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">10 – 25 €</div>
                    <div class="btr-val">30 – 60 €</div>
                    <div class="btr-val btr-val--luxe">100 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">2 – 5 €</div>
                    <div class="btr-val">5 – 15 €</div>
                    <div class="btr-val btr-val--luxe">20 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">1 € (métro)</div>
                    <div class="btr-val">3 – 10 €</div>
                    <div class="btr-val btr-val--luxe">10 – 25 €</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">10 – 30 €</div>
                    <div class="btr-val">30 – 50 €</div>
                    <div class="btr-val btr-val--luxe">50 – 80 €</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">400 – 700 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance pour les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Bangkok ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={`${t.nom} à Bangkok`} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour voyager à Bangkok entre amis</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Un voyage à Bangkok,<br /><em>ça marque à vie</em></h2>
                <p>À Bangkok, la culture, la gastronomie, la fête et l'aventure se vivent à chaque instant. Perds-toi avec tes amis dans les ruelles des marchés flottants, admire les temples dorés au coucher du soleil et sirote un cocktail sur un rooftop avec vue sur la skyline.</p>
                <p>Et surtout — c'est 10 fois mieux quand on le vit entre amis.</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Bangkok%20blog/18.jpg" />
                    <img src="/images/Bangkok%20blog/18.jpg" alt="Grand Palais de Bangkok avec ses toits dorés et jardins" loading="lazy" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bangkok%20blog/3.jpg" alt="Croisière de nuit sur la Chao Phraya avec le Wat Arun illuminé à Bangkok" loading="lazy" />
                    </div>
                    <a href="https://www.getyourguide.com/fr-fr/bangkok-l169/" target="_blank" rel="noopener" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bangkok%20blog/8.jpg" alt="Hébergement à Bangkok" loading="lazy" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Bangkok%2C+Province+de+Bangkok%2C+Tha%C3%AFlande&efdco=1&label=fr-fr-booking-desktop-DCpBIW3k2*WIo8XuzMdB9AS652796013276%3Apl%3Ata%3Ap1%3Ap2%3Aac%3Aap%3Aneg%3Afi%3Atikwd-65526620%3Alp9056135%3Ali%3Adec%3Adm&aid=2311236&lang=fr&sb=1&src_elem=sb&src=index&dest_id=-3414440&dest_type=city&ac_position=0&ac_click_type=b&ac_langcode=fr&ac_suggestion_list_length=5&search_selected=true&search_pageview_id=4bad6b0e3e6600a0&ac_meta=GhA0YmFkNmIwZTNlNjYwMGEwIAAoATICZnI6B2Jhbmdrb2tAAEoAUAA%3D&group_adults=2&no_rooms=1&group_children=0" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bangkok%20blog/10.jpg" alt="Transport en Thaïlande" loading="lazy" />
                    </div>
                    <a href="https://www.dpbolvw.net/click-101634807-17115158?url=https%3A%2F%2F12go.asia%2Fen%2Ftravel%2Fbangkok%2Fchiang-mai%3Fdate%3D2026-03-12%26date2%3D2026-03-25%26people%3D2%26direction%3Dforward" target="_blank" rel="noopener sponsored" class="cta-btn cta-btn--ghost">Déplace-toi partout en Thaïlande</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bangkok%20blog/19.jpg" alt="Avion en vol pour Bangkok, Thaïlande" loading="lazy" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — Bangkok entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

