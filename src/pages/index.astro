---
import Layout from '../layouts/Layout.astro';
import { articles } from '../data/articles.js';

// Toujours les 6 articles les plus récents — ajouter en haut de src/data/articles.js
const derniersAjouts = articles.slice(0, 6);

const coupDeCoeur = [
    { nom: "Tokyo", pays: "Japon", desc: "De Shibuya illuminé aux temples ancestraux, Tokyo est une aventure à chaque pas.", img: "/images/2025/10/Photo-Tokyo-a-deflouter-1-1.jpg", href: "/que-faire-a-tokyo-entre-amis-guide-et-bons-plans" },
    { nom: "Maldives", pays: "Maldives", desc: "Plonge dans des lagons turquoise et marche sur des plages de sable blanc inoubliables.", img: "/images/2026/01/Maldives-blog.jpg", href: "/que-faire-aux-maldives-entre-amis-guide-et-bons-plans" },
    { nom: "Bali", pays: "Indonésie", desc: "Entre rizières, temples et fêtes sur la plage, Bali ne ressemble à aucun autre endroit.", img: "/images/2025/10/Photo-Bali-a-deflouter-17.jpg", href: "/que-faire-a-bali-entre-amis-guide-et-bons-plans" },
];

const activites = [
    { nom: "Bali", num: "01", img: "/images/2025/10/Bali-soins-et-bain-de-boue-avec-les-elephants-1.jpg", href: "/10-activites-incontournables-de-bali", desc: "Bain de boue avec les éléphants, surf à Uluwatu, temples au coucher du soleil, fêtes sur la plage de Seminyak... On a sélectionné les 10 expériences qui font vraiment la magie de Bali." },
    { nom: "Tokyo", num: "02", img: "/images/2025/10/vue-aerienne-du-paysage-urbain-de-tokyo-avec-la-montagne-fuji-au-japon-1024x683.jpg", href: "/tokyo-10-activites-incontournables", desc: "Karting déguisé dans Shibuya, vue sur le Mont Fuji, ramen à minuit dans les ruelles de Shinjuku... Tokyo explose tous les compteurs. Voici les 10 activités à ne pas rater." },
    { nom: "Londres", num: "03", img: "/images/2025/11/Londres-a-deflouter-3.jpg", href: "/londres-10-activites-incontournables", desc: "Promenade sur le Tower Bridge au lever du jour, soirée dans un pub du XVIIe siècle, balade en bus rouge à impériale... On t'a sélectionné les 10 incontournables pour vivre Londres à fond." },
    { nom: "Marrakech", num: "04", img: "/images/2025/12/Marrakech-a-deflouter-3-1.jpg", href: "/marrakech-10-activites-incontournables", desc: "Hammam traditionnel, balades nocturnes dans les souks, nuit dans un riad somptueux, excursion dans le désert... 10 activités pour tomber amoureux de Marrakech." },
];

const piedsDansSable = [
    { nom: "Maldives", img: "/images/2026/01/Maldives-blog.jpg", href: "/que-faire-aux-maldives-entre-amis-guide-et-bons-plans", vibe: "Eaux cristallines, sable blanc immaculé et bungalows sur pilotis au-dessus du lagon." },
    { nom: "Zanzibar", img: "/images/2026/01/Zanzibar-a-deflouter-10.jpg", href: "/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans", vibe: "Plages sauvages bordées de cocotiers, baignées par un océan Indien turquoise et chaud." },
    { nom: "Koh Phi Phi", img: "/images/2026/01/Koh-Phi-Phi-Thailand-Blog-1.jpg", href: "/que-faire-a-koh-phi-phi-entre-amis-guide-et-bons-plans", vibe: "Falaises de calcaire plongeant dans des lagons secrets aux couleurs irréelles." },
    { nom: "Bora Bora", img: "/images/2026/01/Maldives-blog.jpg", href: "/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans", vibe: "Le lagon le plus bleu du Pacifique Sud, entouré de coraux et d'un silence absolu." },
];

const fete = [
    { nom: "Ibiza", pays: "Espagne", img: "/images/2025/10/Ibiza-a-deflouter-5.jpg", href: "/ou-faire-la-fete-a-ibiza" },
    { nom: "Las Vegas", pays: "États-Unis", img: "/images/Las-Vegas.jpg", href: "/ou-faire-la-fete-a-las-vegas" },
    { nom: "Amsterdam", pays: "Pays-Bas", img: "/images/2026/01/Amsterdam-1.jpg", href: "/ou-faire-la-fete-a-amsterdam" },
];

const continents = [
    { nom: "Europe", tagline: "Capitales mythiques & côtes inoubliables", img: "/images/2026/01/Split-a-deflouter-10.jpg", href: "/europe", count: "12 destinations" },
    { nom: "Asie", tagline: "Temples, néons et plages secrètes", img: "/images/2025/10/Photo-Tokyo-a-deflouter-1-1.jpg", href: "/asie", count: "10 destinations" },
    { nom: "Amérique", tagline: "De Miami à Vegas, l'excès en beauté", img: "/images/2025/10/Photo-miami-a-deflouter-10.jpg", href: "/amerique", count: "6 destinations" },
    { nom: "Afrique", tagline: "Safari, épices et océan Indien", img: "/images/2026/01/Zanzibar-a-deflouter-10.jpg", href: "/afrique", count: "4 destinations" },
    { nom: "Océanie", tagline: "Coraux, lagons et grands espaces", img: "/images/2026/01/Cairns-Australie.jpg", href: "/oceanie", count: "3 destinations" },
];

---

<Layout title="Destination Souvenir — Voyager entre amis" heroPage={true}>
    <link rel="preload" as="image" href="/images/bora-bora-hero.jpg" slot="head" />

    <!-- ══════════════════════════════════════
         HERO — Parallax + nav dans l'image
    ══════════════════════════════════════ -->
    <section class="hero" id="hero">
        <div class="hero-bg" id="hero-bg"></div>
        <div class="hero-overlay"></div>



        <!-- Texte central -->
        <div class="hero-content">
            <p class="hero-label">Voyager entre amis · Guides &amp; Bons Plans</p>
            <h1>À l'aventure — <em>le monde t'attend !</em></h1>
            <p class="hero-sub">Guides, bons plans et souvenirs inoubliables pour les 18-35 ans qui veulent tout vivre.</p>
            <div class="hero-actions">
                <a href="/ou-partir" class="btn-hero-primary">Explorer les destinations <span>→</span></a>
            </div>
        </div>

        <div class="hero-scroll-hint">
            <span>Explore le monde</span>
            <div class="hint-line"></div>
        </div>
    </section>


    <!-- ══════════════════════════════════════
         1. EXPLORER PAR CONTINENT
         Style : bento grid immersif
    ══════════════════════════════════════ -->
    <section class="section-continents">
        <div class="continents-intro">
            <h2>Par où commencer <em>l'aventure ?</em></h2>
            <p>Choisis ton continent et explore nos guides.</p>
        </div>
        <div class="continents-row">
            {continents.map((c) => (
                <a href={c.href} class="cont-card">
                    <div class="cont-img">
                        <img src={c.img} alt={c.nom} loading="lazy" />
                        <span class="cont-count">{c.count}</span>
                    </div>
                    <div class="cont-body">
                        <h3>{c.nom}</h3>
                        <p>{c.tagline}</p>
                        <span class="cont-link">Explorer →</span>
                    </div>
                </a>
            ))}
        </div>
    </section>


    <!-- ══════════════════════════════════════
         2. NOS DERNIERS AJOUTS
         Style : bande de cards horizontales
    ══════════════════════════════════════ -->
    <section class="section-ajouts">
        <div class="ajouts-header">
            <div class="ajouts-label">
                <span class="pill pill--new">Nouveau</span>
                <h2>Nos derniers ajouts</h2>
            </div>
        </div>
        <div class="ajouts-carousel">
            <button class="ajouts-arrow" id="ajouts-prev" aria-label="Précédent">&#8249;</button>
            <div class="ajouts-outer">
                <div class="ajouts-scroll" id="ajouts-scroll">
                    {derniersAjouts.map((d) => (
                        <a href={d.href} class="ajout-card">
                            <div class="ajout-img">
                                <img src={d.img} alt={d.nom} loading="lazy" />
                                <span class="ajout-tag">{d.tag}</span>
                            </div>
                            <div class="ajout-body">
                                <h3>{d.titre}</h3>
                                <p class="ajout-desc">{d.desc}</p>
                                <span class="ajout-cta">Lire l'article →</span>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
            <button class="ajouts-arrow" id="ajouts-next" aria-label="Suivant">&#8250;</button>
        </div>
    </section>


    <!-- ══════════════════════════════════════
         2. NOS VOYAGES COUP DE COEUR
         Style : asymétrique — 1 grande + 2 compactes
    ══════════════════════════════════════ -->
    <section class="section-cdc">
        <div class="cdc-header">
            <span class="cdc-eyebrow">❤ Coup de cœur</span>
            <h2 class="cdc-title">Ces destinations <em>qui nous ont marqués</em></h2>
            <p class="cdc-sub">Notre équipe a testé, voyagé, vécu. Voici les endroits qu'on n'oublie jamais.</p>
        </div>
        <div class="cdc-layout">
            <!-- Grande card featured -->
            <a href={coupDeCoeur[0].href} class="cdc-featured">
                <div class="cdc-feat-img">
                    <img src={coupDeCoeur[0].img} alt={coupDeCoeur[0].nom} loading="lazy" />
                </div>
                <div class="cdc-feat-body">
                    <span class="cdc-feat-pays">{coupDeCoeur[0].pays}</span>
                    <h3 class="cdc-feat-titre">{coupDeCoeur[0].nom}</h3>
                    <p class="cdc-feat-desc">{coupDeCoeur[0].desc}</p>
                    <span class="cdc-feat-cta">Découvrir la destination →</span>
                </div>
            </a>
            <!-- 2 petites cards compactes -->
            <div class="cdc-smalls">
                {coupDeCoeur.slice(1).map((d) => (
                    <a href={d.href} class="cdc-small">
                        <div class="cdc-small-img">
                            <img src={d.img} alt={d.nom} loading="lazy" />
                        </div>
                        <div class="cdc-small-body">
                            <span class="cdc-small-pays">{d.pays}</span>
                            <h3>{d.nom}</h3>
                            <p>{d.desc}</p>
                            <span class="cdc-small-cta">Découvrir →</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
        <div class="cdc-footer">
            <a href="/ou-partir" class="cdc-link">Explorer toutes les destinations →</a>
        </div>
    </section>


    <!-- ══════════════════════════════════════
         3. ACTIVITÉS INCONTOURNABLES
         Style : bandes éditoriales alternées
    ══════════════════════════════════════ -->
    <section class="section-actu">
        <div class="actu-container">
            <div class="actu-intro">
                <span class="tag-sand">Activités incontournables</span>
                <h2>10 activités incontournables<br /><em>par destination</em></h2>
            </div>
            <div class="actu-list">
                {activites.map((a, i) => (
                    <a href={a.href} class={`actu-band ${i % 2 === 1 ? "actu-band--reverse" : ""}`}>
                        <div class="actu-band-text">
                            <h3>{a.nom}</h3>
                            <p>{a.desc}</p>
                            <span class="actu-band-cta">Voir les 10 activités →</span>
                        </div>
                        <div class="actu-band-img">
                            <img src={a.img} alt={a.nom} loading="lazy" />
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>


    <!-- ══════════════════════════════════════
         4. LES DESTINATIONS PIEDS DANS LE SABLE
         Style : plage / tropical, fond sable
    ══════════════════════════════════════ -->
    <section class="section-plage">
        <div class="plage-wave-top"></div>
        <div class="plage-container">
            <div class="plage-intro">
                <span class="tag-white">Pieds dans le sable</span>
                <h2>Les plus belles<br /><em>plages du monde</em></h2>
                <p>Parce que parfois, tout ce dont on a besoin c'est du sable chaud, une eau cristalline et ses meilleurs amis.</p>
            </div>
            <div class="plage-grid">
                {piedsDansSable.map((d) => (
                    <a href={d.href} class="plage-card">
                        <div class="plage-img-wrap">
                            <img src={d.img} alt={d.nom} loading="lazy" />
                        </div>
                        <div class="plage-info">
                            <h3>{d.nom}</h3>
                            <span class="plage-vibe">{d.vibe}</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
        <div class="plage-wave-bot"></div>
    </section>


    <!-- ══════════════════════════════════════
         5. NEWSLETTER
         Style : club exclusif
    ══════════════════════════════════════ -->
    <section class="section-nl">
        <div class="nl-content">
            <div class="nl-badge">★ Club Voyageurs</div>
            <h2>Reçois les bons plans<br /><em>avant tout le monde</em></h2>
            <p class="nl-perks">Destinations secrètes · Bons plans exclusifs · Codes promo</p>
            <form class="nl-form">
                <input type="email" placeholder="ton@email.com" />
                <button type="submit">Je rejoins le club</button>
            </form>
            <p class="nl-note">Gratuit · Sans spam · Désinscription en 1 clic</p>
        </div>
    </section>


    <!-- ══════════════════════════════════════
         6. OÙ FAIRE LA FÊTE
         Style : sombre, énergie nuit
    ══════════════════════════════════════ -->
    <section class="section-fete">
        <div class="fete-container">
            <div class="fete-intro">
                <span class="fete-eyebrow">Où faire la fête ?</span>
                <h2>Les destinations<br /><em>qui ne dorment pas</em></h2>
            </div>
            <div class="fete-grid">
                {fete.map((f, i) => (
                    <a href={f.href} class={`fete-card ${i === 0 ? "fete-card--big" : ""}`}>
                        <img src={f.img} alt={f.nom} loading="lazy" />
                        <div class="fete-overlay">
                            <span class="fete-pays">{f.pays}</span>
                            <h3>{f.nom}</h3>
                            <span class="fete-btn">Voir le guide</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>

</Layout>

<style>

/* ════════════════════════════
   HERO
════════════════════════════ */
.hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.hero-bg {
    position: absolute;
    inset: -10% 0 -10% 0;
    background: #0d1b2e url('/images/bora-bora-hero.jpg') center / cover no-repeat;
    will-change: transform;
}

.hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(13,27,46,0.15) 0%, rgba(13,27,46,0.45) 100%);
}



/* Contenu central hero */
.hero-content {
    position: relative;
    z-index: 5;
    text-align: center;
    max-width: 820px;
    padding: 2rem;
}

/* Label EA-style avec lignes décoratives */
.hero-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--turquoise-light);
    margin-bottom: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
}
.hero-label::before,
.hero-label::after {
    content: '';
    display: block;
    width: 36px;
    height: 1px;
    background: var(--turquoise-light);
    opacity: 0.6;
}

.hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 8vw, 6rem);
    font-weight: 900;
    line-height: 1.05;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.25);
    margin-bottom: 1rem;
}

.hero h1 em {
    font-style: italic;
    color: var(--turquoise-light);
}

.hero-sub {
    font-size: 1.1rem;
    font-weight: 500;
    color: rgba(255,255,255,0.95);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.65;
    text-shadow: 0 1px 12px rgba(0,0,0,0.4);
}

/* Boutons hero EA-style */
.hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.5rem;
}

.btn-hero-primary,
.btn-hero-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.9rem 2rem;
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
    border: 2px solid transparent;
    white-space: nowrap;
}

.btn-hero-primary span { transition: transform 0.25s; }
.btn-hero-primary:hover span { transform: translateX(4px); }

.btn-hero-primary {
    background: #3dcbbf;
    color: #fff;
    border-color: #3dcbbf;
}
.btn-hero-primary:hover {
    background: #5eeae0;
    border-color: #5eeae0;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(64,201,176,0.4);
}

.btn-hero-ghost {
    background: transparent;
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.4);
}
.btn-hero-ghost:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.8);
    transform: translateY(-2px);
}

/* Scroll hint */
.hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.5);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    z-index: 5;
}

.hint-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
    animation: scrollDown 2s ease infinite;
}

@keyframes scrollDown {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
}


/* ════════════════════════════
   1. DERNIERS AJOUTS
   Style : carousel 4 cards, texte sous image
════════════════════════════ */
.section-ajouts {
    padding: 2rem 0 2.5rem;
    background: #0d1b2e;
}

.ajouts-header {
    max-width: 1280px;
    margin: 0 auto 1rem;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.ajouts-label {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.ajouts-label h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #fff;
}

.pill {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
}

.pill--new {
    background: var(--turquoise);
    color: #fff;
}

/* Rangée carousel : [flèche] [overflow] [flèche] */
.ajouts-carousel {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 1.5rem;
}

.ajouts-arrow {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
    z-index: 2;
}

.ajouts-arrow:hover {
    background: var(--turquoise);
    border-color: var(--turquoise);
}

/* Fenêtre du carousel — clipe les cards hors champ */
.ajouts-outer {
    flex: 1;
    overflow: hidden;
    padding: 0.5rem 1rem 1rem;
}

/* Piste — animée par transform via JS */
.ajouts-scroll {
    display: flex;
    gap: 1rem;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* Exactement 4 cards visibles */
.ajout-card {
    flex: 0 0 calc((100% - 3rem) / 4);
    border-radius: 14px;
    overflow: hidden;
    background: #132438;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
}

.ajout-card:hover {
    border-color: rgba(61,203,191,0.5);
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4);
}

.ajout-img {
    position: relative;
    aspect-ratio: 2/1;
    overflow: hidden;
    flex-shrink: 0;
}

.ajout-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
}

.ajout-card:hover .ajout-img img { transform: scale(1.05); }

.ajout-tag {
    position: absolute;
    top: 0.7rem; left: 0.7rem;
    background: var(--turquoise);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
}

.ajout-body {
    padding: 1rem 1.2rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    border-top: 2px solid rgba(61,203,191,0.2);
}

.ajout-body h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 900;
    color: #ffffff;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.ajout-desc {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.ajout-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--turquoise-light);
