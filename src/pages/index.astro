    function handleParallax() {
        if (heroBg && window.scrollY < window.innerHeight) {
            heroBg.style.transform = `translateY(${window.scrollY * 0.25}px)`;
        }
    }
    window.addEventListener("scroll", handleParallax, { passive: true });

    // Carousel "Nos derniers ajouts"
    const ajoutsTrack = document.getElementById("ajouts-scroll");
    const ajoutsCards = ajoutsTrack?.querySelectorAll(".ajout-card");
    let ajoutsIndex = 0;
    const ajoutsTotal = ajoutsCards?.length ?? 0;
    const ajoutsVisible = 4;

    function ajoutsMove() {
        if (!ajoutsTrack || !ajoutsCards?.length) return;
        const cardW = (ajoutsCards[0] as HTMLElement).offsetWidth + 16;
        ajoutsTrack.style.transform = `translateX(-${ajoutsIndex * cardW}px)`;
    }

    document.getElementById("ajouts-prev")?.addEventListener("click", () => {
        if (ajoutsIndex > 0) { ajoutsIndex--; ajoutsMove(); }
    });
    document.getElementById("ajouts-next")?.addEventListener("click", () => {
        if (ajoutsIndex < ajoutsTotal - ajoutsVisible) { ajoutsIndex++; ajoutsMove(); }
    });
</script>
