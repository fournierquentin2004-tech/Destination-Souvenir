</style>

<script>
    // Parallax hero
    const heroBg = document.getElementById("hero-bg");
    function handleParallax() {
        if (heroBg && window.scrollY < window.innerHeight) {
            heroBg.style.transform = `translateY(${window.scrollY * 0.25}px)`;
        }
    }
    window.addEventListener("scroll", handleParallax, { passive: true });

    // Carousel "Nos derniers ajouts"
    const ajoutsTrack = document.getElementById("ajouts-scroll");
    const ajoutsCards = ajoutsTrack?.querySelectorAll(".ajout-card");
    let ajoutsIndex = 0;

    function getVisible() {
        const cards = Array.from(ajoutsCards ?? []) as HTMLElement[];
        const visibles = cards.filter(c => c.offsetWidth > 0);
        if (!visibles.length) return 4;
        const outer = ajoutsTrack?.parentElement as HTMLElement;
        return Math.max(1, Math.round(outer.offsetWidth / (visibles[0].offsetWidth + 16)));
    }

    function getTotal() {
        return (Array.from(ajoutsCards ?? []) as HTMLElement[]).filter(c => c.offsetWidth > 0).length;
    }

    function ajoutsMove() {
        if (!ajoutsTrack || !ajoutsCards?.length) return;
        const firstVisible = (Array.from(ajoutsCards) as HTMLElement[]).find(c => c.offsetWidth > 0);
        if (!firstVisible) return;
        const gap = parseFloat(getComputedStyle(ajoutsTrack).gap) || 16;
        const cardW = firstVisible.offsetWidth + gap;
        ajoutsTrack.style.transform = `translateX(-${ajoutsIndex * cardW}px)`;
    }

    function updateDots() {
        document.querySelectorAll(".ajouts-dot").forEach((d, i) => {
            d.classList.toggle("active", i === ajoutsIndex);
        });
    }

    document.getElementById("ajouts-prev")?.addEventListener("click", () => {
        if (ajoutsIndex > 0) { ajoutsIndex--; ajoutsMove(); updateDots(); }
    });
    document.getElementById("ajouts-next")?.addEventListener("click", () => {
        if (ajoutsIndex < getTotal() - getVisible()) { ajoutsIndex++; ajoutsMove(); updateDots(); }
    });

    // Scroll natif mobile — mise à jour des dots
    const ajoutsOuter = document.querySelector(".ajouts-outer") as HTMLElement;
    ajoutsOuter?.addEventListener("scroll", () => {
        const firstVisible = (Array.from(ajoutsCards ?? []) as HTMLElement[]).find(c => c.offsetWidth > 0);
        if (!firstVisible) return;
        const cardW = firstVisible.offsetWidth + 16;
        ajoutsIndex = Math.round(ajoutsOuter.scrollLeft / cardW);
        updateDots();
    }, { passive: true });

    // Accordéon activités (mobile)
    document.querySelectorAll(".actu-band, .actu-band--reverse").forEach(band => {
        band.addEventListener("click", (e) => {
            if (window.innerWidth > 767) return;
            const isOpen = band.classList.contains("is-open");
            if (!isOpen) {
                e.preventDefault();
                document.querySelectorAll(".actu-band, .actu-band--reverse").forEach(b => b.classList.remove("is-open"));
                band.classList.add("is-open");
            }
        });
    });

    // Swipe tactile (desktop uniquement — mobile utilise scroll natif)
    let touchStartX = 0;
    ajoutsTrack?.addEventListener("touchstart", e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    ajoutsTrack?.addEventListener("touchend", e => {
        if (window.innerWidth <= 767) return;
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
            if (diff > 0 && ajoutsIndex < getTotal() - getVisible()) { ajoutsIndex++; ajoutsMove(); updateDots(); }
            if (diff < 0 && ajoutsIndex > 0) { ajoutsIndex--; ajoutsMove(); updateDots(); }
        }
    }, { passive: true });
</script>
