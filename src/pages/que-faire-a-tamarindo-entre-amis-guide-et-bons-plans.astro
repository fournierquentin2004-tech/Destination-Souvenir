---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Excursion plongée", desc: "Plonge dans des eaux cristallines autour des îles Catalinas, nage avec des raies manta, croise des requins de récif et admire les bancs de poissons colorés. Une journée sous-marine inoubliable pour les aventuriers du groupe !", img: "/images/Tamarindo%20Costa%20Rica%20blog/6.webp", alt: "Plongeurs avec une tortue de mer dans les eaux du Costa Rica à Tamarindo", lien: "https://www.getyourguide.com/fr-fr/tamarin-l995/las-catalinas-decouvrez-la-plongee-sous-marine-a-flamingo-et-tamarindo-t752273/?ranking_uuid=762c5f8f-b68e-42e2-ad0f-125920946fe4" },
    { titre: "Cascades Sensoria", desc: "Entre au cœur de la forêt tropicale de Sensoria. Savoure un cocktail de bienvenue, explore des cascades aux eaux cristallines et détends-toi dans des piscines thermales naturelles sous la canopée. Une expérience unique entre aventure, nature et bien-être.", img: "/images/Tamarindo%20Costa%20Rica%20blog/4.webp", alt: "Cascade dans la forêt tropicale du Costa Rica près de Tamarindo", lien: "https://www.getyourguide.com/guanacaste-l592/guancaste-eco-luxury-thermals-and-waterfalls-experience-t433489/" },
    { titre: "Sunset en catamaran", desc: "Navigue au coucher du soleil sur un catamaran, observe dauphins, tortues et baleines, fais du snorkeling dans une baie isolée et profite de l'open bar avec tes amis. Le coucher de soleil costaricain depuis le large est l'une des plus belles expériences du voyage.", img: "/images/Tamarindo%20Costa%20Rica%20blog/7.webp", alt: "Catamaran au coucher de soleil à Tamarindo, Costa Rica", lien: "https://www.getyourguide.com/fr-fr/tamarin-l995/tamarindo-excursion-en-catamaran-au-coucher-du-soleil-t450417/?ranking_uuid=67b913f7-ee42-4e6a-8b28-ea174e7f304c&q=Tamarin" },
];

const hebergements = [
    { type: "Centre de Tamarindo", ex: "Animé, bars, restaurants et vie nocturne", desc: "Le cœur battant de Tamarindo. Tout est à portée de main : restaurants variés, bars, boutiques et accès rapide à la plage principale. Parfait pour un groupe qui veut maximiser les soirées et les sorties sans perdre de temps en déplacement.", tag: "Budget" },
    { type: "Playa Langosta", ex: "Tranquille, plage et couchers de soleil", desc: "Le bon équilibre entre calme et proximité du centre. Quartier plus résidentiel avec des hôtels de charme face à la mer, des couchers de soleil spectaculaires et une ambiance détendue. Idéal pour les groupes qui veulent se ressourcer sans être loin de l'action.", tag: "Équilibre" },
    { type: "Playa Grande", ex: "Chic, nature et ambiance tranquille", desc: "L'option luxe et nature de Tamarindo. Des resorts haut de gamme, une plage préservée fréquentée par les tortues luth la nuit, et une atmosphère calme et exclusive. Parfait pour un groupe qui cherche le grand frisson de la nature sauvage costaricaine.", tag: "Luxe" },
];

const transports = [
    { nom: "À pied", desc: "Le meilleur moyen d'explorer le centre de Tamarindo. La plage principale, les restaurants, les boutiques et les bars sont tous accessibles à pied depuis le cœur du village. Pratique, simple et agréable sous le soleil costaricain.", img: "/images/Tamarindo%20Costa%20Rica%20blog/3.webp", alt: "Forêt tropicale du Costa Rica à explorer à pied depuis Tamarindo" },
    { nom: "Taxi", desc: "Indispensable pour les excursions dans la région ou les trajets vers d'autres plages. Les taxis locaux sont faciles à trouver et peu coûteux. Idéal la nuit ou pour rejoindre des spots plus éloignés comme Playa Grande ou les points de départ d'excursions.", img: "/images/Tamarindo%20Costa%20Rica%20blog/12.webp", alt: "Taxi à Tamarindo pour se déplacer au Costa Rica" },
    { nom: "Scooter", desc: "La meilleure option pour explorer la région en totale liberté. Loue un scooter et découvre les plages sauvages alentour, les forêts tropicales et les points de vue cachés à ton rythme. Une aventure en soi !", img: "/images/Tamarindo%20Costa%20Rica%20blog/14.webp", alt: "Scooter pour explorer Tamarindo et la région au Costa Rica" },
];

const conseils = [
    { titre: "Période idéale", desc: "Décembre à mars — 32°C en moyenne, ciel bleu et mer calme. La saison sèche est parfaite pour profiter des plages, des excursions en mer et de la faune costaricaine dans les meilleures conditions." },
    { titre: "Évite la saison des pluies", desc: "De juin à novembre, les pluies sont fréquentes et intenses. Certaines routes peuvent être difficiles d'accès et quelques excursions annulées. Si tu viens à cette période, prévois des activités adaptées." },
    { titre: "Réserve à l'avance", desc: "Les excursions populaires (plongée aux Catalinas, catamaran sunset, Sensoria) se remplissent rapidement en haute saison. Réserve tes activités dès que possible pour être sûr d'avoir de la place." },
    { titre: "Prends ton vol tôt", desc: "L'aéroport de Liberia (LIR) est le plus proche de Tamarindo — environ 1h de route. Réserve ton billet d'avion au moins 6 mois à l'avance pour obtenir les meilleures tarifs sur cette destination encore confidentielle." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire à Tamarindo entre amis ?", r: "Les incontournables : plongée aux îles Catalinas pour nager avec les raies manta et les requins de récif, excursion aux cascades et piscines thermales de Sensoria au cœur de la forêt tropicale, et coucher de soleil en catamaran avec snorkeling et open bar. Sans oublier le surf sur les vagues parfaites de Tamarindo !" },
    { q: "Où dormir à Tamarindo ?", r: "Le centre de Tamarindo pour être au cœur de l'animation, des restaurants et des bars. Playa Langosta pour un bon équilibre entre tranquillité et proximité du centre. Playa Grande pour une ambiance chic, nature et préservée, avec des plages à tortues la nuit." },
    { q: "Quand partir à Tamarindo ?", r: "La période idéale pour partir à Tamarindo est de décembre à mars, avec un climat sec, un ciel dégagé et des températures autour de 32°C. C'est la haute saison parfaite pour les excursions en mer, les plages et toutes les activités outdoor." },
];

const similaires = [
    { titre: "Que faire à Koh Phi Phi entre amis", desc: "Eaux turquoise, plages de sable blanc et soirées les pieds dans le sable — Koh Phi Phi, c'est le paradis absolu.", img: "/images/Koh%20Phi%20Phi%20blog/5.webp", href: "/que-faire-a-koh-phi-phi-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à El Nido entre amis", desc: "Lagons cachés, falaises calcaires et plages désertes — El Nido, le joyau sauvage des Philippines.", img: "/images/El%20Nido%20Philippines%20blog/1.webp", href: "/que-faire-a-el-nido-aux-philippines-entre-amis-guide-et-bons-plans", tag: "Asie" },
    { titre: "Que faire à Bali entre amis", desc: "Rizières en terrasses, temples mystérieux et nuits festives à Seminyak — Bali, l'île des dieux qui envoûte tous les voyageurs.", img: "/images/Bali%20blog/1.webp", href: "/que-faire-a-bali-entre-amis-guide-et-bons-plans", tag: "Asie" },
];
---

<Layout
    title="Que faire à Tamarindo entre amis : guide et bons plans 2026"
    description="Plongée aux îles Catalinas, cascades Sensoria et coucher de soleil en catamaran. Découvre notre guide complet pour un séjour inoubliable à Tamarindo au Costa Rica."
    ogImage="/images/Tamarindo%20Costa%20Rica%20blog/1.webp"
    canonicalPath="/que-faire-a-tamarindo-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
    touristName="Tamarindo"
    touristCountry="Costa Rica"
>
    <link rel="preload" as="image" href="/images/Tamarindo%20Costa%20Rica%20blog/1.webp" slot="head" />

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Tamarindo entre amis : guide et bons plans 2026",
        "description": "Plongée aux îles Catalinas, cascades Sensoria et coucher de soleil en catamaran. Découvre notre guide complet pour un séjour inoubliable à Tamarindo au Costa Rica.",
        "image": "https://destinationsouvenir.com/images/Tamarindo%20Costa%20Rica%20blog/1.webp",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2026-06-14",
        "dateModified": "2026-06-14",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-tamarindo-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire à Tamarindo entre amis ?", "acceptedAnswer": { "@type": "Answer", "text": "Les incontournables : plongée aux îles Catalinas pour nager avec les raies manta et les requins de récif, excursion aux cascades et piscines thermales de Sensoria au cœur de la forêt tropicale, et coucher de soleil en catamaran avec snorkeling et open bar. Sans oublier le surf sur les vagues parfaites de Tamarindo !" } },
            { "@type": "Question", "name": "Où dormir à Tamarindo ?", "acceptedAnswer": { "@type": "Answer", "text": "Le centre de Tamarindo pour être au cœur de l'animation, des restaurants et des bars. Playa Langosta pour un bon équilibre entre tranquillité et proximité du centre. Playa Grande pour une ambiance chic, nature et préservée, avec des plages à tortues la nuit." } },
            { "@type": "Question", "name": "Quand partir à Tamarindo ?", "acceptedAnswer": { "@type": "Answer", "text": "La période idéale pour partir à Tamarindo est de décembre à mars, avec un climat sec, un ciel dégagé et des températures autour de 32°C. C'est la haute saison parfaite pour les excursions en mer, les plages et toutes les activités outdoor." } }
        ]
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Amérique", "item": "https://destinationsouvenir.com/amerique" },
            { "@type": "ListItem", "position": 3, "name": "Tamarindo", "item": "https://destinationsouvenir.com/que-faire-a-tamarindo-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Amérique &nbsp;·&nbsp; Costa Rica</p>
            <h1>Que faire à <em>Tamarindo</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Plongée, cascades tropicales et catamarans au coucher du soleil… Tamarindo, c'est <em>le Costa Rica dans toute sa splendeur sauvage.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Tamarindo entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <picture>
                                    <img src={a.img} alt={a.alt} loading="lazy" />
                                </picture>
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Tamarindo%20Costa%20Rica%20blog/9.webp" alt="Volcan Arenal et forêt tropicale du Costa Rica" loading="lazy" width="1920" height="1280" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Tamarindo%20Costa%20Rica%20blog/2.webp" alt="Plage de sable blanc et eaux turquoise à Tamarindo, Costa Rica" loading="lazy" width="1920" height="1080" />
            <img src="/images/Tamarindo%20Costa%20Rica%20blog/11.webp" alt="Vue aérienne de la baie de Tamarindo, Costa Rica" loading="lazy" width="3840" height="2160" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Tamarindo%20Costa%20Rica%20blog/10.webp" alt="Vue aérienne de la côte et des îlots du Costa Rica près de Tamarindo" loading="lazy" width="1920" height="1280" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Tamarindo%20Costa%20Rica%20blog/16.webp" alt="Piscine avec palmiers dans un resort à Tamarindo, Costa Rica" loading="lazy" width="1080" height="1350" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Tamarindo ?</em></h2>
                <p class="logements-sub">Du centre animé aux plages sauvages — le quartier que tu choisis change complètement l'ambiance de ton séjour au Costa Rica.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Tamarindo%20Costa%20Rica%20blog/8.webp" alt="Resort avec piscine tropicale à Tamarindo, Costa Rica" loading="lazy" width="1280" height="720" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve ton hébergement plusieurs mois à l'avance, surtout pour décembre et janvier — la haute saison est très courte et les meilleures adresses partent en quelques heures !</span>
                </p>
                <a href="https://www.booking.com/hotel/cr/pasatiempo.fr.html" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Tamarindo</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Tamarindo&nbsp;?</em></h2>
                <p>Tamarindo s'adapte à tous les profils — des voyageurs budget aux groupes qui veulent profiter sans compter.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val">50 – 100 €</div>
                    <div class="btr-val btr-val--luxe">150 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">5 – 12 €</div>
                    <div class="btr-val">15 – 30 €</div>
                    <div class="btr-val btr-val--luxe">40 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">2 – 5 €</div>
                    <div class="btr-val">10 – 15 €</div>
                    <div class="btr-val btr-val--luxe">25 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">10 – 20 €</div>
                    <div class="btr-val">25 – 60 €</div>
                    <div class="btr-val btr-val--luxe">100 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">500 – 1 000 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> l'aéroport de Liberia (LIR) est le plus proche de Tamarindo — environ 1h de route. Préfère-le à San José pour économiser jusqu'à 2h de trajet !</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Tamarindo ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt ?? `${t.nom} à Tamarindo`} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à Tamarindo</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Tamarindo,<br /><em>le Costa Rica qui te prend par surprise</em></h2>
                <p>Tamarindo est le spot parfait pour allier plage, surf et activités tropicales. Ici, tu as tout à portée de main : plages magnifiques, spots de surf accessibles dès le premier jour, et excursions pour découvrir les mangroves ou la vie marine.</p>
                <p>Que tu viennes pour l'action ou la détente, Tamarindo te garantit un séjour intense, fun et mémorable — avec le coucher de soleil costaricain le plus spectaculaire que tu aies jamais vu.</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Tamarindo%20Costa%20Rica%20blog/5.webp" />
                    <img src="/images/Tamarindo%20Costa%20Rica%20blog/5.webp" alt="Coucher de soleil sur la plage de Tamarindo, Costa Rica" loading="lazy" width="1920" height="1080" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Tamarindo%20Costa%20Rica%20blog/6.webp" alt="Activités à Tamarindo entre amis — plongée au Costa Rica" loading="lazy" width="1920" height="1080" />
                    </div>
                    <a href="https://www.getyourguide.com/s/?q=tamarindo&searchSource=3" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Tamarindo%20Costa%20Rica%20blog/8.webp" alt="Hébergement avec piscine à Tamarindo, Costa Rica" loading="lazy" width="1280" height="720" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Tamarindo" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Tamarindo%20Costa%20Rica%20blog/15.webp" alt="4x4 sur une piste au Costa Rica depuis Tamarindo" loading="lazy" width="1080" height="1350" />
                    </div>
                    <a href="https://www.tkqlhce.com/click-101634807-17115158?url=https%3A%2F%2F12go.asia%2Fen%2Ftravel%2Fsan-jose%2Ftamarindo" target="_blank" rel="noopener sponsored" class="cta-btn cta-btn--ghost">Déplace-toi partout au Costa Rica</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
