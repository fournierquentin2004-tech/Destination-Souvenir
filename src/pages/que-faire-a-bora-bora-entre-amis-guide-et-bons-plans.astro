---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Paradis sous-marin", desc: "Plonge dans le lagon turquoise de Bora Bora et découvre un monde sous-marin majestueux : raies pastenagues curieuses, jardins coralliens préservés et requins impressionnants. Embarque sur un outrigger traditionnel et vis une aventure unique !", img: "/images/Bora%20Bora%20blog/4.webp", alt: "Plongée en apnée dans le lagon turquoise de Bora Bora", lien: "https://www.getyourguide.com/fr-fr/bora-bora-l32139/bora-bora-visite-du-lagon-et-plongee-en-apnee-t405215/?ranking_uuid=13d45c46-4c63-483c-bbc3-4637f416219d" },
    { titre: "Aventure en jet ski", desc: "Pars en jet ski sur les eaux turquoise de Bora Bora et amuse-toi tout en admirant des paysages magiques, avec le mont Otemanu comme panorama. Arrête-toi pour capturer des photos incroyables et profite d'une après-midi unique au cœur de ce coin de paradis !", img: "/images/Bora%20Bora%20blog/5.webp", alt: "Jet ski sur le lagon de Bora Bora avec vue sur le mont Otemanu", lien: "https://www.getyourguide.com/fr-fr/plage-de-matira-bora-bora-l122245/jet-ski-autour-de-bora-bora-la-vitesse-au-paradis-t953746/?ranking_uuid=13d45c46-4c63-483c-bbc3-4637f416219d" },
    { titre: "Survol de Bora Bora", desc: "Embarque pour un vol inoubliable au-dessus des plages bordées de cocotiers et des récifs coralliens. Admire l'un des lagons les plus beaux du monde depuis les airs, puis continue vers Tahaa, l'île à la vanille, pour des paysages à couper le souffle.", img: "/images/Bora%20Bora%20blog/6.webp", alt: "Vue aérienne de Bora Bora et son lagon turquoise depuis un avion", lien: "https://www.getyourguide.com/fr-fr/raiatea-l32627/raiatea-bora-bora-et-taha-a-vol-panoramique-prive-d-une-heure-t827320/?ranking_uuid=13d45c46-4c63-483c-bbc3-4637f416219d" },
];

const hebergements = [
    { type: "Vaitape", ex: "Hôtels, pensions et auberges", desc: "À deux pas des boutiques, restaurants et de l'animation locale. L'option idéale pour être au cœur de la vie de l'île et rejoindre facilement les embarcadères.", tag: "Animé" },
    { type: "Pofai", ex: "Pensions et petits hôtels", desc: "Calme et reposant, face au lagon. Parfait pour les petites pensions de famille et un séjour détente loin de l'agitation, avec de belles vues sur l'eau.", tag: "Détente" },
    { type: "Faanui", ex: "Resorts de luxe et bungalows sur pilotis", desc: "Pour un séjour d'exception dans des resorts directement en bord de mer ou sur un motu privé. L'expérience Bora Bora dans toute sa splendeur.", tag: "Luxe" },
];

const transports = [
    { nom: "Navettes bateau", desc: "Indispensables si tu loges sur un motu. Les ferries relient les différents hôtels et l'île principale — inclus dans la plupart des séjours en resort.", img: "/images/Bora%20Bora%20blog/8.webp", alt: "Navette bateau sur le lagon de Bora Bora" },
    { nom: "Excursions organisées", desc: "Souvent le meilleur moyen de découvrir le lagon, les motus et les activités nautiques. Tout est prévu — idéal pour profiter sans se soucier de la logistique.", img: "/images/Bora%20Bora%20blog/9.webp", alt: "Excursion organisée en bateau sur le lagon de Bora Bora" },
    { nom: "Taxi", desc: "Disponibles sur l'île principale mais coûteux. Pratiques pour les courtes distances entre Vaitape et les points d'intérêt. Négocie le prix avant de monter.", img: "/images/Bora%20Bora%20blog/18.webp", alt: "Transport en taxi sur l'île de Bora Bora" },
];

const conseils = [
    { titre: "Période idéale", desc: "Mai à octobre, pendant la saison sèche et ensoleillée, avec des températures idéales entre 27 et 30°C. La saison des pluies (novembre-avril) est moins recommandée." },
    { titre: "Indispensables", desc: "Crème solaire haute protection et anti-moustique sont essentiels. Le soleil polynésien est intense — protège-toi même sous l'eau lors des plongées !" },
    { titre: "Sécurité", desc: "Bora Bora est une destination très sûre. Les seuls risques sont le coup de soleil et la déshydratation — hydrate-toi régulièrement et évite de plonger seul." },
    { titre: "Respect du lagon", desc: "Ne jette rien dans le lagon et respecte les coraux lors de tes plongées. Ce trésor naturel fragile mérite d'être préservé pour les générations futures." },
];

const faq = [
    { q: "Quelle est la meilleure période pour aller à Bora Bora ?", r: "La meilleure période s'étend de mai à octobre, pendant la saison sèche et ensoleillée, avec des températures agréables autour de 27 à 30°C. Idéal pour profiter du lagon et des activités nautiques." },
    { q: "Quelles sont les meilleures activités à faire entre amis à Bora Bora ?", r: "Les incontournables : snorkeling avec raies et requins dans le lagon, jet-ski autour de l'île avec vue sur le mont Otemanu, survol en avion privé, sunset cruise et pique-nique sur un motu privé. Une destination où chaque activité est inoubliable !" },
    { q: "Où dormir à Bora Bora ?", r: "Vaitape pour être proche de l'animation locale, Pofai pour un séjour calme et détente près du lagon, Faanui pour les resorts de luxe et les bungalows sur pilotis en bord de mer." },
];

const similaires = [
    { titre: "Que faire à Sydney entre amis", desc: "Opéra, plages mythiques, Harbour Bridge et une énergie unique — Sydney est l'une des villes les plus époustouflantes au monde.", img: "/images/Sydney%20blog/8.webp", href: "/que-faire-a-sydney-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Cairns entre amis", desc: "Plongée dans la Grande Barrière de Corail, vol en hélicoptère et plages tropicales — Cairns est le paradis australien de l'aventure.", img: "/images/Cairns%20blog/3.webp", href: "/que-faire-a-cairns-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire aux Maldives entre amis", desc: "Sable blanc, eaux cristallines et vie marine à couper le souffle — les Maldives sont une destination de rêve absolu.", img: "/images/Maldives%20blog/1.webp", href: "/que-faire-aux-maldives-entre-amis-guide-et-bons-plans", tag: "Océan Indien" },
];
---

<Layout
    title="Que faire à Bora Bora entre amis : guide et bons plans 2026"
    description="Plages de sable blanc, eaux turquoise et couchers de soleil à couper le souffle. Guide complet pour un séjour inoubliable à Bora Bora entre amis : activités, hébergement et budget."
    ogImage="/images/Bora%20Bora%20blog/1.webp"
    canonicalPath="/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans"
    heroPage={true}
    ogType="article"
    touristName="Bora Bora"
    touristCountry="Polynésie française"
>
    <link rel="preload" as="image" href="/images/Bora%20Bora%20blog/1.webp" slot="head" />

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Que faire à Bora Bora entre amis : guide et bons plans 2026",
        "description": "Plages de sable blanc, eaux turquoise et couchers de soleil à couper le souffle. Guide complet pour un séjour inoubliable à Bora Bora entre amis : activités, hébergement et budget.",
        "image": "https://destinationsouvenir.com/images/Bora%20Bora%20blog/1.webp",
        "author": { "@type": "Organization", "name": "Destination Souvenir", "url": "https://destinationsouvenir.com" },
        "publisher": { "@type": "Organization", "name": "Destination Souvenir", "logo": { "@type": "ImageObject", "url": "https://destinationsouvenir.com/logo.png" } },
        "datePublished": "2025-11-10",
        "dateModified": "2026-06-08",
        "mainEntityOfPage": { "@type": "WebPage", "@id": "https://destinationsouvenir.com/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans" },
        "inLanguage": "fr-FR"
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            { "@type": "Question", "name": "Quelle est la meilleure période pour aller à Bora Bora ?", "acceptedAnswer": { "@type": "Answer", "text": "La meilleure période s'étend de mai à octobre, pendant la saison sèche et ensoleillée, avec des températures agréables autour de 27 à 30°C." } },
            { "@type": "Question", "name": "Quelles sont les meilleures activités à faire entre amis à Bora Bora ?", "acceptedAnswer": { "@type": "Answer", "text": "Snorkeling avec raies et requins dans le lagon, jet-ski autour de l'île avec vue sur le mont Otemanu, survol en avion privé, sunset cruise et pique-nique sur un motu." } },
            { "@type": "Question", "name": "Où dormir à Bora Bora ?", "acceptedAnswer": { "@type": "Answer", "text": "Vaitape pour l'animation locale, Pofai pour un séjour calme près du lagon, Faanui pour les resorts de luxe et bungalows sur pilotis." } }
        ]
    })}</script>

    <script is:inline type="application/ld+json" slot="head">{JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://destinationsouvenir.com" },
            { "@type": "ListItem", "position": 2, "name": "Océanie", "item": "https://destinationsouvenir.com/oceanie" },
            { "@type": "ListItem", "position": 3, "name": "Bora Bora", "item": "https://destinationsouvenir.com/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans" }
        ]
    })}</script>

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Pacifique <span class="kicker-sep">&nbsp;·&nbsp;</span> Bora&nbsp;Bora</p>
            <h1>Que faire à <em>Bora Bora</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Les pieds dans le sable blanc, face à un lagon d'un turquoise presque irréel. Le soleil caresse ta peau, un cocktail à la main, et autour de toi tout devient simple, léger, suspendu. Prépare-toi à vivre un voyage inoubliable&nbsp;!</p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>à Bora Bora entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <img src={a.img} alt={a.alt} loading="lazy" />
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">Découvrir l'activité</a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img class="mosaic-img--desktop" src="/images/Bora%20Bora%20blog/11.webp" alt="Vue panoramique du lagon de Bora Bora et du mont Otemanu" loading="lazy" width="1080" height="1920" />
            <img class="mosaic-img--mobile" src="/images/Bora%20Bora%20blog/16.webp" alt="Vue panoramique du lagon de Bora Bora et du mont Otemanu" loading="lazy" width="1920" height="1280" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Bora%20Bora%20blog/13.webp" alt="Bungalow sur pilotis au-dessus du lagon de Bora Bora" loading="lazy" width="1920" height="1122" />
            <img src="/images/Bora%20Bora%20blog/2.webp" alt="Plage de sable blanc à Bora Bora au coucher du soleil" loading="lazy" width="1920" height="1080" />
        </div>
        <div class="mosaic-a">
            <img class="mosaic-img--desktop" src="/images/Bora%20Bora%20blog/16.webp" alt="Raies pastenagues dans les eaux cristallines de Bora Bora" loading="lazy" width="1920" height="1280" />
            <img class="mosaic-img--mobile" src="/images/Bora%20Bora%20blog/11.webp" alt="Raies pastenagues dans les eaux cristallines de Bora Bora" loading="lazy" width="1080" height="1920" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Bora%20Bora%20blog/7.webp" alt="Bungalow sur pilotis avec vue sur le lagon de Bora Bora" loading="lazy" width="1280" height="720" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>à Bora Bora ?</em></h2>
                <p class="logements-sub">De l'animation de Vaitape aux resorts de luxe sur motu — Bora Bora offre des hébergements pour tous les styles et tous les budgets.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Bora%20Bora%20blog/7.webp" alt="Bungalow sur pilotis avec vue sur le lagon de Bora Bora" loading="lazy" width="1280" height="720" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve plusieurs mois à l'avance pour les resorts sur pilotis — les meilleurs partent très vite, surtout en haute saison&nbsp;!</span>
                </p>
                <a href="https://www.booking.com/hotel/pf/intercontinental-bora-bora-le-moana-resort.fr.html?lang=fr" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement à Bora Bora</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage à Bora Bora&nbsp;?</em></h2>
                <p>Bora Bora est une destination premium — mais il existe des options pour tous les budgets, des pensions locales aux resorts de rêve.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">70 – 150 €</div>
                    <div class="btr-val">190 – 320 €</div>
                    <div class="btr-val btr-val--luxe">600 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">10 – 20 €</div>
                    <div class="btr-val">25 – 50 €</div>
                    <div class="btr-val btr-val--luxe">80 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">0 – 10 €</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val btr-val--luxe">60 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">30 – 80 €</div>
                    <div class="btr-val">90 – 150 €</div>
                    <div class="btr-val btr-val--luxe">200 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">1 200 – 2 000 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance — les vols vers Tahiti sont chers et se remplissent vite.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>à Bora Bora ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.alt} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--sand">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi à Bora Bora</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Bora Bora,<br /><em>un rêve éveillé</em></h2>
                <p>Visiter Bora Bora, c'est entrer dans un tableau vivant. Entre lagon turquoise, plages de sable blanc et mont Otemanu qui se reflète dans l'eau, chaque instant est un émerveillement.</p>
                <p>Snorkeling avec les raies, jet-ski sous le soleil, couchers de soleil depuis un bungalow sur pilotis… tu rentreras avec des souvenirs plein la tête — et l'envie irrésistible d'y retourner.</p>
            </div>
            <div class="conclusion-img-wrap">
                <img src="/images/Bora%20Bora%20blog/17.webp" alt="Coucher de soleil sur le lagon de Bora Bora avec le mont Otemanu en arrière-plan" loading="lazy" width="1920" height="1440" />
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bora%20Bora%20blog/20.webp" alt="Activités à Bora Bora, snorkeling dans le lagon" loading="lazy" width="1080" height="1920" />
                    </div>
                    <a href="https://www.getyourguide.com/fr-fr/bora-bora-l32139/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bora%20Bora%20blog/14.webp" alt="Hébergement à Bora Bora, bungalow sur pilotis" loading="lazy" width="1920" height="1280" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?ss=Bora-Bora" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Bora%20Bora%20blog/19.webp" alt="Vol pour Bora Bora, Polynésie française" loading="lazy" width="1920" height="1241" />
                    </div>
                    <a href="https://www.skyscanner.fr/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>FAQ — Bora Bora entre amis :<br /><em>vos questions</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;
        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }
        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));
        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) { current = index; dots.forEach((d, i) => d.classList.toggle('active', i === current)); }
        }, { passive: true });
    }

    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => { if (other !== item) (other as HTMLDetailsElement).open = false; });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => { heroBg.style.transform = `translateY(${window.scrollY * 0.45}px)`; };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

