---
import Layout from '../layouts/Layout.astro';

const activites = [
    { num: "01", titre: "Excursion snorkeling", desc: "Embarque sur un bateau et explore les lagons turquoise des Maldives. Nage parmi les coraux éclatants et les poissons colorés, détends-toi sur des bancs de sable blanc et rencontre des dauphins curieux. Une aventure à vivre absolument !", img: "/images/Maldives%20blog/2.jpg", alt: "Snorkeling dans les lagons turquoise des Maldives", lien: "https://www.getyourguide.com/fr-fr/male-l159176/voyage-d-aventure-aux-maldives-t614694/?ranking_uuid=3f2070e2-a76d-4c91-8505-1f34de183c96" },
    { num: "02", titre: "Rencontre avec les tortues", desc: "Plonge dans des eaux transparentes pour découvrir poissons tropicaux et récifs colorés, puis admire les tortues en liberté et savoure un déjeuner sur un banc de sable immaculé.", img: "/images/Maldives%20blog/3.jpg", alt: "Tortues marines dans les eaux cristallines des Maldives", lien: "https://www.getyourguide.com/fr-fr/maafushi-l159192/maafushi-tour-en-bateau-avec-plongee-en-apnee-dans-les-jardins-de-corail-et-dejeuner-t728674/?ranking_uuid=3f2070e2-a76d-4c91-8505-1f34de183c96" },
    { num: "03", titre: "Nage avec les requins-nourrices", desc: "Nage au plus près des requins-nourrices et découvre leur comportement paisible dans leur habitat naturel. Admire leur élégance sous l'eau et leur façon d'évoluer autour des récifs coralliens. Une rencontre marine unique et fascinante !", img: "/images/Maldives%20blog/4.jpg", alt: "Requins-nourrices dans les récifs coralliens des Maldives", lien: "https://www.getyourguide.com/fr-fr/bodufolhudhoo-l254183/experience-locale-requin-nourrice-et-recifs-caches-de-l-atoll-d-ari-t1127988/?ranking_uuid=3f2070e2-a76d-4c91-8505-1f34de183c96" },
];

const hebergements = [
    { icon: "🏡", type: "Îles locales", ex: "Maafushi, Dhiffushi, Thulusdhoo", desc: "Parfait pour les groupes. Budget raisonnable, ambiance conviviale et accès aux activités.", tag: "Budget" },
    { icon: "🛖", type: "Guesthouses", ex: "Sur les îles habitées", desc: "Excellent compromis entre budget et authenticité. Contact direct avec la culture locale.", tag: "Équilibre" },
    { icon: "🌊", type: "Villas sur pilotis", ex: "Resorts privés", desc: "L'expérience iconique des Maldives. À vivre au moins une nuit pour le souvenir.", tag: "Luxe" },
];

const transports = [
    { icon: "🚤", nom: "Hors-bord", desc: "Rapide et pratique entre les îles. Idéal pour les excursions.", img: "/images/Maldives%20blog/6.jpg" },
    { icon: "⛵", nom: "Dhoni local", desc: "Économique mais horaires fixes. L'âme des Maldives.", img: "/images/Maldives%20blog/11.jpg" },
    { icon: "✈️", nom: "Hydravion", desc: "Expérience unique et panoramique. Spectaculaire mais onéreux.", img: "/images/Maldives%20blog/7.jpg" },
];

const conseils = [
    { icon: "🌤️", titre: "Meilleure période", desc: "Décembre à avril — 28°C en moyenne, temps sec et mer calme." },
    { icon: "🏨", titre: "Réserve tôt", desc: "Hôtel et activités à réserver plusieurs mois à l'avance pour les meilleurs prix." },
    { icon: "☀️", titre: "Crème solaire bio", desc: "Indispensable. Privilégie une formule biodégradable pour protéger les coraux." },
    { icon: "✈️", titre: "Vol en avance", desc: "Réserve ton vol tôt pour profiter des meilleures offres et avoir plus de choix." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire aux Maldives entre amis ?", r: "Snorkeling et plongée dans les lagons turquoise, nage avec les tortues marines, excursion sur une île déserte, sunset cruise avec dauphins, et nage avec les requins-nourrices. Chaque expérience est unique et inoubliable." },
    { q: "Où dormir aux Maldives ?", r: "Trois options selon ton budget : les îles locales comme Maafushi (budget raisonnable, ambiance conviviale), les guesthouses sur les îles habitées (bon compromis budget / authenticité), ou les villas sur pilotis en resort privé (expérience iconique à vivre au moins une nuit)." },
    { q: "Quand partir aux Maldives ?", r: "La période idéale s'étend de décembre à avril, avec des températures autour de 28°C et un climat sec parfait pour profiter des plages et des activités nautiques. Évite la saison des pluies (mai à novembre) si tu veux du soleil garanti." },
];

const similaires = [
    { titre: "Que faire à Cairns entre amis", desc: "Plongée dans la Grande Barrière de Corail, forêts tropicales et aventures en plein air.", img: "/images/2026/01/Cairns-Australie.jpg", href: "/que-faire-a-cairns-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Bora Bora entre amis", desc: "Le lagon le plus bleu du Pacifique, bungalows sur pilotis et couchers de soleil inoubliables.", img: "/images/bora-bora-hero.jpg", href: "/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Zanzibar entre amis", desc: "Plages sauvages, épices envoûtantes et couchers de soleil sur l'océan Indien.", img: "/images/2026/01/Zanzibar-a-deflouter-10.jpg", href: "/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans", tag: "Afrique" },
];
---

<Layout
    title="Que faire aux Maldives entre amis : guide et bons plans 2026"
    description="Tu prépares un voyage aux Maldives entre amis ? Snorkeling, tortues, îles désertes, sunset cruise... Découvre le guide complet avec activités, hébergement et budget."
    ogImage="/images/Maldives%20blog/16.jpg"
    canonicalPath="/que-faire-aux-maldives-entre-amis-guide-et-bons-plans"
    heroPage={true}
>
    <link rel="preload" as="image" href="/images/Maldives%20blog/16.jpg" slot="head" />

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Asie &nbsp;·&nbsp; Maldives</p>
            <h1>Que faire aux <em>Maldives</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Imagine-toi au milieu d'un décor irréel, entouré de lagons turquoise et de plages de sable blanc. Les journées s'enchaînent entre baignades, excursions snorkeling et moments hors du temps. Aux Maldives, <em>le quotidien disparaît dès ton arrivée.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS (grid de cartes) ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>aux Maldives entre amis</em></h2>
            </div>
            <div class="acts-grid">
                {activites.map((a) => (
                    <article class="act-card">
                        <div class="act-card-img">
                            <img src={a.img} alt={a.alt} loading="lazy" />
                            <span class="act-num">{a.num}</span>
                        </div>
                        <div class="act-card-body">
                            <h3>{a.titre}</h3>
                            <p>{a.desc}</p>
                            <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                Découvrir l'activité
                            </a>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Maldives%20blog/8.jpg" alt="Bungalow sur pilotis aux Maldives" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Maldives%20blog/9.jpg" alt="Plage de sable blanc aux Maldives" loading="lazy" />
            <img src="/images/Maldives%20blog/10.jpg" alt="Récif corallien aux Maldives" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Maldives%20blog/11.jpg" alt="Bateau dhoni traditionnel" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-hd">
                <span class="pill pill--white">Où dormir</span>
                <h2>Où se loger<br /><em>aux Maldives ?</em></h2>
                <p>Des îles locales aux villas sur pilotis — il y en a pour tous les budgets.</p>
            </div>
            <div class="logements-grid">
                {hebergements.map((h) => (
                    <div class="logement-card">
                        <div class="logement-top">
                            <span class="logement-icon">{h.icon}</span>
                            <span class="logement-tag">{h.tag}</span>
                        </div>
                        <h3>{h.type}</h3>
                        <p class="logement-ex">{h.ex}</p>
                        <p class="logement-desc">{h.desc}</p>
                    </div>
                ))}
            </div>
            <p class="tip">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve plusieurs mois à l'avance, surtout en haute saison (décembre–avril).</span>
            </p>
            <div class="logements-cta">
                <a href="https://www.booking.com/searchresults.fr.html?dest_id=975&dest_type=country" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">🏨 Trouver un hébergement aux Maldives</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET (tableau 3 niveaux) ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage aux Maldives ?</em></h2>
                <p>Contrairement aux idées reçues, les Maldives peuvent être accessibles hors resorts de luxe.</p>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">1 300 – 1 900 €</span>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">🏡 Hébergement</div>
                    <div class="btr-val">60 – 110 €</div>
                    <div class="btr-val">120 – 200 €</div>
                    <div class="btr-val btr-val--luxe">400 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">🍽️ Repas</div>
                    <div class="btr-val">11 – 19 €</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val btr-val--luxe">70 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">🚤 Transport</div>
                    <div class="btr-val">5 – 15 €</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val btr-val--luxe">80 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">🤿 Activités</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val">60 – 120 €</div>
                    <div class="btr-val btr-val--luxe">200 €+</div>
                </div>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance pour les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/vols-pour/mv/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">✈️ Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT (3 cartes avec image) ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>aux Maldives ?</em></h2>
            </div>
            <div class="transport-grid">
                {transports.map((t) => (
                    <div class="transport-card">
                        <div class="transport-img">
                            <img src={t.img} alt={t.nom} loading="lazy" />
                            <div class="transport-img-veil"></div>
                            <span class="transport-icon">{t.icon}</span>
                        </div>
                        <div class="transport-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS (2×2 icon boxes) ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--white">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c) => (
                    <div class="conseil-card">
                        <span class="conseil-icon">{c.icon}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <img src="/images/Maldives%20blog/12.jpg" alt="Coucher de soleil sur le lagon des Maldives" loading="lazy" class="conclusion-img" />
        <div class="conclusion-overlay">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Un voyage aux Maldives,<br /><em>ça change une vie</em></h2>
                <p>Lagons turquoise, fonds marins incroyables, îles désertes et moments chill sur la plage. Une destination taillée pour créer des souvenirs inoubliables dans un décor de carte postale.</p>
                <p>Et surtout — c'est 10 fois mieux quand on le vit entre amis.</p>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">✈️ Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-btns">
                <a href="https://www.getyourguide.fr/maldives-l975/" target="_blank" rel="noopener" class="cta-btn cta-btn--dark">🤿 Réserver une activité</a>
                <a href="https://www.booking.com/searchresults.fr.html?dest_id=975&dest_type=country" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">🏨 Trouver un hébergement</a>
                <a href="https://www.skyscanner.fr/vols-pour/mv/" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">✈️ Comparer les vols</a>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>Tout ce que tu dois savoir<br /><em>avant de partir</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true"></span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>


<script>
    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => {
            const y = window.scrollY;
            heroBg.style.transform = `translateY(${y * 0.45}px)`;
        };
        window.addEventListener('scroll', onScroll, { passive: true });
    }
</script>

</Layout>

<style>

/* ══════════════════════════════
   HERO
══════════════════════════════ */
.hero {
    position: relative;
    height: 100vh;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
}
.hero-bg {
    position: absolute;
    inset: -8%;
    background-size: cover;
    background-position: center;
    background-image: url('/images/Maldives%20blog/16.jpg');
}
@media (max-width: 767px) {
    .hero-bg { background-image: url('/images/Maldives%20blog/14.jpg'); }
}
.hero-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
        rgba(13,27,46,0.28) 0%,
        rgba(13,27,46,0.42) 50%,
        rgba(13,27,46,0.65) 100%
    );
}
.hero-cnt {
    position: relative;
    z-index: 5;
    color: #fff;
    padding: 0 2rem;
    max-width: 700px;
    transform: translateY(4vh);
}
.hero-kicker {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.95);
    margin-bottom: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    text-shadow: 0 1px 12px rgba(0,0,0,0.55);
}
.hero-kicker::before, .hero-kicker::after {
    content: '';
    width: 36px;
    height: 1.5px;
    background: var(--turquoise-light);
}
.hero-cnt h1 {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 5.6rem);
    font-weight: 900;
    line-height: 1.08;
    margin-bottom: 1.6rem;
    text-shadow: 0 2px 40px rgba(0,0,0,0.45);
}
.hero-cnt h1 em { font-style: italic; color: var(--turquoise-light); }
.hero-rule { width: 48px; height: 1px; background: rgba(255,255,255,0.35); margin: 0 auto 1.2rem; }
.hero-meta {
    font-family: var(--font-sans);
    font-size: 0.84rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 1px 10px rgba(0,0,0,0.4);
    margin-bottom: 2rem;
}
.hero-intro {
    font-family: var(--font-serif);
    font-size: clamp(0.98rem, 1.8vw, 1.15rem);
    font-weight: 400;
    color: rgba(255,255,255,0.92);
    line-height: 1.8;
    text-shadow: 0 1px 20px rgba(0,0,0,0.7), 0 2px 6px rgba(0,0,0,0.5);
    max-width: 540px;
    margin: 0 auto;
}
.hero-intro em {
    font-style: italic;
    color: var(--turquoise-light);
    font-weight: 600;
}


/* ══════════════════════════════
   PILLS
══════════════════════════════ */
.pill {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    margin-bottom: 1rem;
}
.pill--sand { background: var(--sand); color: var(--green-dark); }
.pill--white { background: rgba(255,255,255,0.75); backdrop-filter: blur(4px); color: var(--green-dark); }
.pill--turquoise { background: var(--turquoise); color: #fff; }




/* ══════════════════════════════
   STRIP PHOTO
══════════════════════════════ */
.strip { height: 58vh; overflow: hidden; }
.strip img { width: 100%; height: 100%; object-fit: cover; display: block; }


/* ══════════════════════════════
   ACTIVITÉS (grid de cartes)
══════════════════════════════ */
.acts { background: #fff; padding: 6rem 2rem; }
.acts-inner { max-width: 1280px; margin: 0 auto; }
.acts-hd {
    text-align: center;
    margin-bottom: 3.5rem;
}
.acts-hd h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--green-dark);
    line-height: 1.1;
}
.acts-hd h2 em { font-style: italic; color: var(--turquoise); }

.acts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
}

.act-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(13,27,46,0.08);
    box-shadow: 0 4px 24px rgba(13,27,46,0.07);
    display: flex;
    flex-direction: column;
    transition: transform 0.35s, box-shadow 0.35s;
}
.act-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(13,27,46,0.14); }

.act-card-img {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
}
.act-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
}
.act-card:hover .act-card-img img { transform: scale(1.06); }

.act-num {
    position: absolute;
    top: 1rem;
    left: 1rem;
    width: 36px;
