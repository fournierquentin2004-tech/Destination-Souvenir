---
import Layout from '../layouts/Layout.astro';

const activites = [
    { titre: "Excursion snorkeling", desc: "Embarque sur un bateau et explore les lagons turquoise des Maldives. Nage parmi les coraux éclatants et les poissons colorés, détends-toi sur des bancs de sable blanc et rencontre des dauphins curieux. Une aventure à vivre absolument !", img: "/images/Maldives%20blog/13.jpg", alt: "Snorkeling dans les lagons turquoise des Maldives", lien: "https://www.getyourguide.com/fr-fr/male-l159176/voyage-d-aventure-aux-maldives-t614694/?ranking_uuid=3f2070e2-a76d-4c91-8505-1f34de183c96" },
    { titre: "Rencontre avec les tortues", desc: "Parcours les îles et les lagons scintillants des Maldives à bord d'un hors-bord. Plonge dans des eaux transparentes pour découvrir poissons tropicaux et récifs colorés, puis admire les tortues en liberté et savoure un déjeuner sur un banc de sable immaculé.", img: "/images/Maldives%20blog/1.jpg", alt: "Tortues marines dans les eaux cristallines des Maldives", lien: "https://www.getyourguide.com/fr-fr/maafushi-l159192/maafushi-tour-en-bateau-avec-plongee-en-apnee-dans-les-jardins-de-corail-et-dejeuner-t728674/?ranking_uuid=3f2070e2-a76d-4c91-8505-1f34de183c96" },
    { titre: "Nage avec les requins-nourrices", desc: "Nage au plus près des requins-nourrices et découvre leur comportement paisible dans leur habitat naturel. Admire leur taille impressionnante, leur élégance sous l'eau et la manière dont ils évoluent autour des récifs coralliens. Une rencontre marine unique et fascinante !", img: "/images/Maldives%20blog/4.jpg", alt: "Requins-nourrices dans les récifs coralliens des Maldives", lien: "https://www.getyourguide.com/fr-fr/bodufolhudhoo-l254183/experience-locale-requin-nourrice-et-recifs-caches-de-l-atoll-d-ari-t1127988/?ranking_uuid=3f2070e2-a76d-4c91-8505-1f34de183c96" },
];

const hebergements = [
    { icon: "🏡", type: "Îles locales", ex: "Maafushi, Dhiffushi, Thulusdhoo", desc: "Parfait pour les groupes. Budget raisonnable, ambiance conviviale et accès aux activités.", tag: "Budget" },
    { icon: "🛖", type: "Guesthouses", ex: "Sur les îles habitées", desc: "Excellent compromis entre budget et authenticité. Contact direct avec la culture locale.", tag: "Équilibre" },
    { icon: "🌊", type: "Villas sur pilotis", ex: "Resorts privés", desc: "L'expérience iconique des Maldives. À vivre au moins une nuit pour le souvenir.", tag: "Luxe" },
];

const transports = [
    { icon: "🚤", nom: "Speed boat", desc: "Rapide et pratique entre les îles. Idéal pour les excursions.", img: "/images/Maldives%20blog/9.jpg" },
    { icon: "⛵", nom: "Dhoni local", desc: "Économique mais horaires fixes. L'âme des Maldives.", img: "/images/Maldives%20blog/10.jpg" },
    { icon: "✈️", nom: "Hydravion", desc: "Expérience unique et panoramique. Spectaculaire mais onéreux.", img: "/images/Maldives%20blog/11.jpg" },
];

const conseils = [
    { icon: "🌤️", titre: "Meilleure période", desc: "Décembre à avril — 28°C en moyenne, temps sec et mer calme." },
    { icon: "🏨", titre: "Réserve tôt", desc: "Hôtel et activités à réserver plusieurs mois à l'avance pour les meilleurs prix." },
    { icon: "☀️", titre: "Crème solaire bio", desc: "Indispensable. Privilégie une formule biodégradable pour protéger les coraux." },
    { icon: "✈️", titre: "Vol en avance", desc: "Réserve ton vol tôt pour profiter des meilleures offres et avoir plus de choix." },
];

const faq = [
    { q: "Quelles sont les meilleures activités à faire aux Maldives entre amis ?", r: "Snorkeling et plongée dans les lagons turquoise, nage avec les tortues marines, excursion sur une île déserte, sunset cruise avec dauphins, et nage avec les requins-nourrices. Chaque expérience est unique et inoubliable." },
    { q: "Où dormir aux Maldives ?", r: "Trois options selon ton budget : les îles locales comme Maafushi (budget raisonnable, ambiance conviviale), les guesthouses sur les îles habitées (bon compromis budget / authenticité), ou les villas sur pilotis en resort privé (expérience iconique à vivre au moins une nuit)." },
    { q: "Quand partir aux Maldives ?", r: "La période idéale s'étend de décembre à avril, avec des températures autour de 28°C et un climat sec parfait pour profiter des plages et des activités nautiques. Évite la saison des pluies (mai à novembre) si tu veux du soleil garanti." },
];

const similaires = [
    { titre: "Que faire à Cairns entre amis", desc: "Plongée dans la Grande Barrière de Corail, forêts tropicales et aventures en plein air.", img: "/images/2026/01/Cairns-Australie.jpg", href: "/que-faire-a-cairns-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Bora Bora entre amis", desc: "Le lagon le plus bleu du Pacifique, bungalows sur pilotis et couchers de soleil inoubliables.", img: "/images/bora-bora-hero.jpg", href: "/que-faire-a-bora-bora-entre-amis-guide-et-bons-plans", tag: "Océanie" },
    { titre: "Que faire à Zanzibar entre amis", desc: "Plages sauvages, épices envoûtantes et couchers de soleil sur l'océan Indien.", img: "/images/2026/01/Zanzibar-a-deflouter-10.jpg", href: "/que-faire-a-zanzibar-entre-amis-guide-et-bons-plans", tag: "Afrique" },
];
---

<Layout
    title="Que faire aux Maldives entre amis : guide et bons plans 2026"
    description="Tu prépares un voyage aux Maldives entre amis ? Snorkeling, tortues, îles désertes, sunset cruise... Découvre le guide complet avec activités, hébergement et budget."
    ogImage="/images/Maldives%20blog/16.jpg"
    canonicalPath="/que-faire-aux-maldives-entre-amis-guide-et-bons-plans"
    heroPage={true}
>
    <link rel="preload" as="image" href="/images/Maldives%20blog/16.jpg" slot="head" />

    <!-- ══ HERO ══ -->
    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-veil"></div>
        <div class="hero-cnt">
            <p class="hero-kicker">Asie &nbsp;·&nbsp; Maldives</p>
            <h1>Que faire aux <em>Maldives</em><br />entre amis&nbsp;?</h1>
            <div class="hero-rule"></div>
            <p class="hero-meta">Guide complet &nbsp;·&nbsp; activités &nbsp;·&nbsp; hébergement &nbsp;·&nbsp; budget</p>
            <p class="hero-intro">Imagine-toi au milieu d'un décor irréel, entouré de lagons turquoise et de plages de sable blanc. Les journées s'enchaînent entre baignades, excursions snorkeling et moments hors du temps. Aux Maldives, <em>le quotidien disparaît dès ton arrivée.</em></p>
        </div>
    </section>


    <!-- ══ ACTIVITÉS (grid de cartes) ══ -->
    <section class="acts" id="activites">
        <div class="acts-inner">
            <div class="acts-hd">
                <span class="pill pill--sand">À faire absolument</span>
                <h2>3 activités incontournables<br /><em>aux Maldives entre amis</em></h2>
            </div>
            <div class="acts-carousel" id="actsCarousel">
                <button class="carousel-btn carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="acts-grid">
                    {activites.map((a) => (
                        <article class="act-card">
                            <div class="act-card-img">
                                <img src={a.img} alt={a.alt} loading="lazy" />
                            </div>
                            <div class="act-card-body">
                                <h3>{a.titre}</h3>
                                <p>{a.desc}</p>
                                <a href={a.lien} target="_blank" rel="noopener noreferrer" class="act-btn">
                                    Découvrir l'activité
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
                <button class="carousel-btn carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="carousel-dots">
                    {activites.map((_, i) => (
                        <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


    <!-- ══ GALERIE MOSAÏQUE ══ -->
    <div class="mosaic">
        <div class="mosaic-a">
            <img src="/images/Maldives%20blog/17.jpg" alt="Bungalow sur pilotis aux Maldives" loading="lazy" />
        </div>
        <div class="mosaic-b">
            <img src="/images/Maldives%20blog/12.jpg" alt="Plage de sable blanc aux Maldives" loading="lazy" />
            <img src="/images/Maldives%20blog/21.jpg" alt="Récif corallien aux Maldives" loading="lazy" />
        </div>
        <div class="mosaic-a">
            <img src="/images/Maldives%20blog/8.jpg" alt="Bateau dhoni traditionnel" loading="lazy" />
        </div>
    </div>


    <!-- ══ HÉBERGEMENT ══ -->
    <section class="logements" id="hebergement">
        <div class="logements-inner">
            <div class="logements-img logements-img--desktop">
                <img src="/images/Maldives%20blog/5.jpg" alt="Bungalow sur pilotis aux Maldives" loading="lazy" />
            </div>
            <div class="logements-content">
                <span class="pill pill--sand">Où dormir</span>
                <h2>Où se loger<br /><em>aux Maldives ?</em></h2>
                <p class="logements-sub">Des îles locales aux villas sur pilotis — il y en a pour tous les budgets.</p>
                <div class="logements-list">
                    {hebergements.map((h) => (
                        <div class="logement-item">
                            <div class="logement-item-hd">
                                <h3>{h.type}</h3>
                                <span class="logement-tag">{h.tag}</span>
                            </div>
                            <p class="logement-ex">{h.ex}</p>
                            <p class="logement-desc">{h.desc}</p>
                        </div>
                    ))}
                </div>
                <div class="logements-img logements-img--mobile">
                    <img src="/images/Maldives%20blog/5.jpg" alt="Bungalow sur pilotis aux Maldives" loading="lazy" />
                </div>
                <p class="tip">
                    <span><strong>Astuce :</strong> réserve plusieurs mois à l'avance, surtout en haute saison (décembre–avril).</span>
                </p>
                <a href="https://www.booking.com/searchresults.fr.html?dest_id=975&dest_type=country" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--dark">Trouver un hébergement aux Maldives</a>
            </div>
        </div>
    </section>


    <!-- ══ BUDGET (tableau 3 niveaux) ══ -->
    <section class="budget" id="budget">
        <div class="budget-inner">
            <div class="budget-hd">
                <span class="pill pill--turquoise">Budget</span>
                <h2>Combien coûte<br /><em>un voyage aux Maldives ?</em></h2>
                <p>Contrairement aux idées reçues, les Maldives peuvent être accessibles hors resorts de luxe.</p>
            </div>

            <div class="budget-table">
                <div class="budget-table-head">
                    <div class="bth-cell bth-label">Dépense / jour</div>
                    <div class="bth-cell bth-col bth-col--budget">Budget</div>
                    <div class="bth-cell bth-col bth-col--moyen">Moyen</div>
                    <div class="bth-cell bth-col bth-col--luxe">Luxe</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Hébergement</div>
                    <div class="btr-val">60 – 110 €</div>
                    <div class="btr-val">120 – 200 €</div>
                    <div class="btr-val btr-val--luxe">400 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Repas</div>
                    <div class="btr-val">11 – 19 €</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val btr-val--luxe">70 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Transport</div>
                    <div class="btr-val">5 – 15 €</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val btr-val--luxe">80 €+</div>
                </div>
                <div class="budget-table-row">
                    <div class="btr-label">Activités</div>
                    <div class="btr-val">20 – 40 €</div>
                    <div class="btr-val">60 – 120 €</div>
                    <div class="btr-val btr-val--luxe">200 €+</div>
                </div>
            </div>

            <div class="budget-total">
                <span class="budget-total-lbl">1 semaine · par personne · hors vol</span>
                <span class="budget-total-range">1 300 – 1 900 €</span>
            </div>

            <p class="tip tip--light">
                <span>💡</span>
                <span><strong>Astuce :</strong> réserve ton vol plusieurs mois à l'avance pour les meilleures offres.</span>
            </p>
            <div class="budget-cta">
                <a href="https://www.skyscanner.fr/vols-pour/mv/" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--turquoise">Comparer les vols sur Skyscanner</a>
            </div>
        </div>
    </section>


    <!-- ══ TRANSPORT ══ -->
    <section class="transport" id="transport">
        <div class="transport-inner">
            <div class="transport-hd">
                <span class="pill pill--sand">Déplacements</span>
                <h2>Comment se déplacer<br /><em>aux Maldives ?</em></h2>
            </div>
            <div class="transport-list">
                {transports.map((t) => (
                    <div class="transport-item">
                        <div class="transport-item-img">
                            <img src={t.img} alt={t.nom} loading="lazy" />
                        </div>
                        <div class="transport-item-body">
                            <h3>{t.nom}</h3>
                            <p>{t.desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONSEILS (2×2 icon boxes) ══ -->
    <section class="conseils" id="conseils">
        <div class="conseils-inner">
            <div class="conseils-hd">
                <span class="pill pill--white">Avant de partir</span>
                <h2>Conseils pratiques<br /><em>pour un voyage réussi</em></h2>
            </div>
            <div class="conseils-grid">
                {conseils.map((c, i) => (
                    <div class="conseil-card">
                        <span class="conseil-num">0{i + 1}</span>
                        <h3>{c.titre}</h3>
                        <p>{c.desc}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ CONCLUSION ══ -->
    <section class="conclusion">
        <div class="conclusion-inner">
            <div class="conclusion-body">
                <span class="pill pill--turquoise">Pourquoi y aller ?</span>
                <h2>Un voyage aux Maldives,<br /><em>ça change une vie</em></h2>
                <p>Lagons turquoise, fonds marins incroyables, îles désertes et moments chill sur la plage. Une destination taillée pour créer des souvenirs inoubliables dans un décor de carte postale.</p>
                <p>Et surtout — c'est 10 fois mieux quand on le vit entre amis.</p>
            </div>
            <div class="conclusion-img-wrap">
                <picture>
                    <source media="(min-width: 768px)" srcset="/images/Maldives%20blog/13.jpg" />
                    <img src="/images/Maldives%20blog/12.jpg" alt="Coucher de soleil sur le lagon des Maldives" loading="lazy" />
                </picture>
            </div>
        </div>
    </section>


    <!-- ══ CTA ══ -->
    <section class="cta">
        <div class="cta-inner">
            <div class="nl-badge">Prêt à partir ?</div>
            <h2>Prépare ton séjour<br /><em>dès maintenant</em></h2>
            <p class="cta-sub">Réserve tes activités, ton hébergement et ton vol au meilleur prix.</p>
            <div class="cta-cards">
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Maldives%20blog/1.jpg" alt="Activités aux Maldives" loading="lazy" />
                    </div>
                    <a href="https://www.getyourguide.fr/maldives-l975/" target="_blank" rel="noopener" class="cta-btn cta-btn--dark">Réserver une activité</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Maldives%20blog/8.jpg" alt="Hébergement aux Maldives" loading="lazy" />
                    </div>
                    <a href="https://www.booking.com/searchresults.fr.html?dest_id=975&dest_type=country" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">Trouver un hébergement</a>
                </div>
                <div class="cta-card">
                    <div class="cta-card-img">
                        <img src="/images/Maldives%20blog/22.jpg" alt="Vol pour les Maldives" loading="lazy" />
                    </div>
                    <a href="https://www.skyscanner.fr/vols-pour/mv/" target="_blank" rel="noopener" class="cta-btn cta-btn--ghost">Comparer les vols</a>
                </div>
            </div>
        </div>
    </section>


    <!-- ══ FAQ ══ -->
    <section class="faq" id="faq">
        <div class="faq-inner">
            <div class="faq-hd">
                <span class="pill pill--sand">Questions fréquentes</span>
                <h2>Tout ce que tu dois savoir<br /><em>avant de partir</em></h2>
            </div>
            <div class="faq-list">
                {faq.map((item, i) => (
                    <details class="faq-item" open={i === 0}>
                        <summary class="faq-question">
                            <span>{item.q}</span>
                            <span class="faq-chevron" aria-hidden="true">
                                <svg width="14" height="8" viewBox="0 0 14 8" fill="none">
                                    <line x1="1" y1="1" x2="7" y2="7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                    <line x1="7" y1="7" x2="13" y2="1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                                </svg>
                            </span>
                        </summary>
                        <div class="faq-answer">
                            <p>{item.r}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>


    <!-- ══ ARTICLES SIMILAIRES ══ -->
    <section class="similaires">
        <div class="similaires-inner">
            <h2 class="sim-title">Ces articles aussi <em>vont te plaire</em></h2>
            <div class="sim-carousel" id="simCarousel">
                <button class="sim-carousel-btn sim-carousel-btn--prev" aria-label="Précédent">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <div class="sim-grid">
                {similaires.map((s) => (
                    <a href={s.href} class="sim-card">
                        <div class="sim-img">
                            <img src={s.img} alt={s.titre} loading="lazy" />
                            <span class="sim-tag">{s.tag}</span>
                        </div>
                        <div class="sim-body">
                            <h3>{s.titre}</h3>
                            <p>{s.desc}</p>
                            <span class="sim-cta">Lire l'article →</span>
                        </div>
                    </a>
                ))}
                </div>
                <button class="sim-carousel-btn sim-carousel-btn--next" aria-label="Suivant">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="sim-carousel-dots">
                    {similaires.map((_, i) => (
                        <span class={`sim-dot${i === 0 ? ' active' : ''}`} data-index={String(i)}></span>
                    ))}
                </div>
            </div>
        </div>
    </section>


<script>
    // Carousel activités (mobile uniquement)
    const carousel = document.getElementById('actsCarousel');
    if (carousel && window.innerWidth <= 767) {
        const grid = carousel.querySelector('.acts-grid') as HTMLElement;
        const cards = carousel.querySelectorAll('.act-card');
        const dots = carousel.querySelectorAll('.carousel-dot');
        const prevBtn = carousel.querySelector('.carousel-btn--prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.carousel-btn--next') as HTMLElement;
        let current = 0;

        function goTo(index: number) {
            current = ((index % cards.length) + cards.length) % cards.length;
            grid.scrollTo({ left: current * grid.offsetWidth, behavior: 'smooth' });
            dots.forEach((d, i) => d.classList.toggle('active', i === current));
        }

        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

        grid.addEventListener('scroll', () => {
            const index = Math.round(grid.scrollLeft / grid.offsetWidth);
            if (index !== current) {
                current = index;
                dots.forEach((d, i) => d.classList.toggle('active', i === current));
            }
        }, { passive: true });
    }

    // Carousel articles similaires (mobile uniquement)
    const simCarousel = document.getElementById('simCarousel');
    if (simCarousel && window.innerWidth <= 767) {
        const simGrid = simCarousel.querySelector('.sim-grid') as HTMLElement;
        const simCards = simCarousel.querySelectorAll('.sim-card');
        const simDots = simCarousel.querySelectorAll('.sim-dot');
        const simPrev = simCarousel.querySelector('.sim-carousel-btn--prev') as HTMLElement;
        const simNext = simCarousel.querySelector('.sim-carousel-btn--next') as HTMLElement;
        let simCurrent = 0;
        function simGoTo(index: number) {
            simCurrent = ((index % simCards.length) + simCards.length) % simCards.length;
            simGrid.scrollTo({ left: simCurrent * simGrid.offsetWidth, behavior: 'smooth' });
            simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent));
        }
        simPrev?.addEventListener('click', () => simGoTo(simCurrent - 1));
        simNext?.addEventListener('click', () => simGoTo(simCurrent + 1));
        simDots.forEach((d, i) => d.addEventListener('click', () => simGoTo(i)));
        simGrid.addEventListener('scroll', () => {
            const index = Math.round(simGrid.scrollLeft / simGrid.offsetWidth);
            if (index !== simCurrent) { simCurrent = index; simDots.forEach((d, i) => d.classList.toggle('active', i === simCurrent)); }
        }, { passive: true });
    }

    // FAQ accordion exclusif
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        item.addEventListener('toggle', () => {
            if ((item as HTMLDetailsElement).open) {
                faqItems.forEach(other => {
                    if (other !== item) (other as HTMLDetailsElement).open = false;
                });
            }
        });
    });

    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
        const onScroll = () => {
            const y = window.scrollY;
            heroBg.style.transform = `translateY(${y * 0.45}px)`;
        };
